<button type="button" class="theme-toggle" aria-label="Switch to dark mode" data-theme-toggle>
  <!-- Moon: shown in light mode (action = go dark) -->
  <svg class="icon icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
  <!-- Sun: shown in dark mode (action = go light) -->
  <svg class="icon icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4"/>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
  </svg>
  <span class="toggle-label" data-theme-label>Dark</span>
</button>

<script>
  const storageKey = 'siren-song-theme';
  const root = document.documentElement;
  const w = window as Window & { __sirenThemeToggleListenerBound?: boolean };

  const getSystemTheme = () => (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');

  const applyTheme = (theme: 'light' | 'dark') => {
    root.dataset.theme = theme;

    document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]').forEach((toggle) => {
      toggle.setAttribute('aria-label', theme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode');
      const label = toggle.querySelector<HTMLSpanElement>('[data-theme-label]');
      if (label) {
        label.textContent = theme === 'dark' ? 'Light' : 'Dark';
      }
    });
  };

  const initializeThemeToggles = () => {
    const savedTheme = localStorage.getItem(storageKey);
    applyTheme(savedTheme === 'dark' || savedTheme === 'light' ? savedTheme : getSystemTheme());

    document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]').forEach((toggle) => {
      if (toggle.dataset.themeBound === 'true') return;

      toggle.addEventListener('click', () => {
        const nextTheme = root.dataset.theme === 'dark' ? 'light' : 'dark';
        localStorage.setItem(storageKey, nextTheme);
        applyTheme(nextTheme);
      });

      toggle.dataset.themeBound = 'true';
    });
  };

  initializeThemeToggles();

  if (!w.__sirenThemeToggleListenerBound) {
    document.addEventListener('astro:page-load', initializeThemeToggles);
    w.__sirenThemeToggleListenerBound = true;
  }
</script>

<style>
  .theme-toggle {
    border: 1px solid var(--color-border-soft);
    background: transparent;
    color: var(--color-text-muted);
    padding: 0.25rem 0.625rem;
    border-radius: var(--radius-sm);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    transition: color 180ms ease, border-color 180ms ease, background 180ms ease;
  }

  .theme-toggle:hover {
    color: var(--color-accent-pop);
    border-color: var(--color-accent-pop);
  }

  :root:not([data-theme="dark"]) .theme-toggle:hover {
    color: color-mix(in oklab, var(--color-accent-pop) 62%, var(--color-text-strong) 38%);
    border-color: color-mix(in oklab, var(--color-accent-pop) 62%, var(--color-text-strong) 38%);
  }

  @media (prefers-reduced-motion: no-preference) {
    .theme-toggle:hover .icon {
      animation: wiggle 400ms ease;
    }
  }

  .toggle-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    line-height: 1;
  }

  /* Show moon in light mode, sun in dark mode */
  :root[data-theme="light"] .icon-sun { display: none; }
  :root[data-theme="dark"] .icon-moon { display: none; }
</style>