<button type="button" class="motion-toggle" aria-label="Reduce motion" data-motion-toggle>
  <!-- Wind: shown when motion is enabled (click to reduce) -->
  <svg class="icon icon-wind" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M17.7 7.7a2.5 2.5 0 1 1 1.8 4.3H2"/>
    <path d="M9.6 4.6A2 2 0 1 1 11 8H2"/>
    <path d="M12.6 19.4A2 2 0 1 0 14 16H2"/>
  </svg>
  <!-- Pause: shown when motion is reduced (click to enable) -->
  <svg class="icon icon-pause" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="6" y="4" width="4" height="16" rx="1"/>
    <rect x="14" y="4" width="4" height="16" rx="1"/>
  </svg>
  <span class="toggle-label" data-motion-label>Motion on</span>
</button>

<script>
  const storageKey = 'siren-song-motion';
  const root = document.documentElement;
  const toggle = document.querySelector<HTMLButtonElement>('[data-motion-toggle]');

  const label = document.querySelector<HTMLSpanElement>('[data-motion-label]');

  const applyMotion = (reduced: boolean) => {
    root.dataset.reducedMotion = reduced ? 'true' : 'false';
    if (toggle) {
      toggle.setAttribute('aria-label', reduced ? 'Enable motion' : 'Reduce motion');
    }
    if (label) {
      label.textContent = reduced ? 'Motion off' : 'Motion on';
    }
    window.dispatchEvent(new CustomEvent('siren-motion-change', { detail: { reduced } }));
  };

  const saved = localStorage.getItem(storageKey);
  const systemReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isReduced = saved !== null ? saved === 'reduce' : systemReduced;
  applyMotion(isReduced);

  toggle?.addEventListener('click', () => {
    const next = root.dataset.reducedMotion !== 'true';
    localStorage.setItem(storageKey, next ? 'reduce' : 'no-preference');
    applyMotion(next);
  });
</script>

<style>
  .motion-toggle {
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);
    border-radius: var(--radius-pill);
    padding: var(--space-2) var(--space-3);
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    transition: background-color 180ms ease, border-color 180ms ease, box-shadow 180ms ease, transform 180ms ease;
  }

  .motion-toggle:hover {
    background: var(--color-surface-strong);
    border-color: var(--color-accent-soft);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 15%, transparent), 0 4px 20px rgba(109, 40, 217, 0.12);
    transform: translateY(-1px);
  }

  :root:not([data-theme="dark"]) .motion-toggle {
    background: color-mix(in oklab, var(--color-surface) 74%, transparent);
    border-color: color-mix(in oklab, var(--color-accent-soft) 45%, white 55%);
    color: var(--color-text-strong);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.65), 0 6px 18px rgba(56, 30, 97, 0.1);
  }

  :root:not([data-theme="dark"]) .motion-toggle:hover {
    background: color-mix(in oklab, var(--color-surface-strong) 78%, transparent);
    border-color: color-mix(in oklab, var(--color-accent-soft) 55%, white 45%);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.72), 0 8px 22px rgba(56, 30, 97, 0.12);
  }

  @media (prefers-reduced-motion: no-preference) {
    .motion-toggle:hover .icon {
      animation: wiggle 400ms ease;
    }
  }

  .toggle-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    line-height: 1;
  }

  /* Show wind when motion enabled, pause when reduced */
  :root[data-reduced-motion="true"] .icon-wind { display: none; }
  :root:not([data-reduced-motion="true"]) .icon-pause { display: none; }
</style>
