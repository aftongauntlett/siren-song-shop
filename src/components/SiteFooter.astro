---
import ThemeToggle from './ThemeToggle.astro';
import MotionToggle from './MotionToggle.astro';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/shop', label: 'Browse Shops' },
  { href: '/get-involved', label: 'Get Involved' },
  { href: '/local', label: 'Local Gems' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
] as const;
---

<footer class="site-footer">
  <div class="container footer-body">
    <!-- Brand column -->
    <div class="footer-brand">
      <a href="/" class="footer-logo" data-astro-prefetch>Siren Song Shop</a>
      <nav class="footer-nav" aria-label="Footer navigation">
        <ul>
          {navLinks.map(({ href, label }) => (
            <li><a href={href} data-astro-prefetch>{label}</a></li>
          ))}
        </ul>
      </nav>
      <div class="footer-toggles" aria-label="Footer controls">
        <ThemeToggle />
        <MotionToggle />
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p class="footer-identity">
        <span class="pride-flag" aria-hidden="true">🏳️‍🌈</span>
        <span>woman-owned &amp; queer-friendly</span>
      </p>
      <p class="footer-copy">© {new Date().getFullYear()} Siren Song Shop</p>
      <span class="built-by">built by <a href="https://www.prettyprettyprettygood.org/" rel="noopener noreferrer" target="_blank">prettyprettyprettygood</a></span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    z-index: 1;
    background: transparent;
  }

  .site-footer::before {
    content: '';
    display: block;
    width: min(100% - 2rem, var(--container-max));
    margin: 0 auto;
    border-top: 1px solid var(--color-border-soft);
  }

  :root:not([data-theme="dark"]) .site-footer::before {
    border-top-color: color-mix(in oklab, var(--color-accent-strong) 18%, var(--color-border-soft) 82%);
  }

  .footer-body {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-5);
    padding: var(--space-8) 0 var(--space-6);
  }

  /* Brand */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: center;
    text-align: center;
  }

  .footer-toggles {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
    border-bottom: 1px solid var(--color-border-soft);
    padding-bottom: var(--space-4);
    width: 100%;
  }

  .footer-logo {
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    font-size: 0.875rem;
    color: var(--color-text-strong);
  }

  :root[data-theme="dark"] .footer-logo {
    color: color-mix(in oklab, white 94%, var(--color-accent-soft));
  }

  .footer-logo:hover,
  :root[data-theme="dark"] .footer-logo:hover {
    color: var(--color-accent-pop);
  }

  /* Nav row */
  .footer-nav {
    width: 100%;
  }

  .footer-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2) var(--space-6);
  }

  .footer-nav a {
    text-decoration: none;
    color: var(--color-text-muted);
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 180ms ease;
  }

  .footer-nav a:hover {
    color: var(--color-accent-pop);
  }

  /* Bottom bar */
  .footer-bottom {
    padding: 0 0 var(--space-2);
  }

  :root:not([data-theme="dark"]) .footer-bottom {
    background: transparent;
  }

  :root:not([data-theme="dark"]) .site-footer .footer-nav a:hover {
    color: color-mix(in oklab, var(--color-accent-pop) 62%, var(--color-text-strong) 38%);
  }

  :root:not([data-theme="dark"]) .site-footer .footer-bottom {
    border-top: none;
  }

  .footer-bottom-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-2) var(--space-5);
  }

  .footer-copy {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.8rem;
    flex: 1 1 auto;
    text-align: center;
    order: 2;
  }

  .footer-identity {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: var(--space-2);
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.75rem;
    white-space: nowrap;
    order: 1;
  }

  .built-by {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    text-align: right;
    white-space: nowrap;
    order: 3;
  }

  @media (max-width: 480px) {
    .footer-bottom-inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .footer-identity,
    .footer-copy,
    .built-by {
      justify-content: center;
      text-align: center;
    }
  }

  .pride-flag {
    font-size: 0.9rem;
    line-height: 1;
  }

  .built-by a {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 180ms ease;
  }

  .built-by a:hover {
    color: var(--color-text-strong);
  }
</style>
