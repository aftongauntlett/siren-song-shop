---
import { Image } from 'astro:assets';
import ButtonLink from './ButtonLink.astro';
import cosmicImg from '../assets/cosmic.jpg';

const shop = {
  name: 'Cosmic Pocket',
  category: 'Arts & Crafts',
  url: 'https://www.instagram.com/cosmic.pocket/',
  description:
    'A multi-media artist and colorist based in Ohio, creating handmade original art sold directly through Instagram. Every piece is one-of-a-kind. No mass production, no middlemen.',
} as const;
---

<section aria-labelledby="spotlight-heading" class="shop-spotlight">
  <h2 id="spotlight-heading" class="section-heading" data-reveal>Shop Spotlight</h2>
  <p class="section-copy spotlight-copy" data-reveal data-reveal-delay="1">One shop we're genuinely into right now. We rotate this out every now and then - this is just our current fave!</p>
  <div class="spotlight-card" data-reveal data-reveal-delay="2">
    <div class="spotlight-image-wrap">
      <Image
        src={cosmicImg}
        alt="Three crocheted bunny plushies in pink, hot pink, and blue against a retro floral backdrop — handmade by Cosmic Pocket"
        width={480}
        height={480}
        class="spotlight-image"
      />
    </div>
    <div class="spotlight-body">
      <div class="spotlight-main">
        <span class="spotlight-category" aria-label={`Category: ${shop.category}`}>{shop.category}</span>
        <h3 class="spotlight-name">{shop.name}</h3>
        <p class="spotlight-desc">{shop.description}</p>
      </div>
      <footer class="spotlight-footer">
        <ButtonLink href={shop.url} variant="ghost" target="_blank" rel="noopener noreferrer">
          Visit the Shop
          <svg class="visit-icon" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M6 3h7v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            <path d="M10 6L3 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </ButtonLink>
      </footer>
    </div>
  </div>
</section>

<style>
  .shop-spotlight {
    /* section spacing handled by :global(section + section) */
  }

  .shop-spotlight > .section-heading,
  .spotlight-copy {
    text-align: center;
  }

  .shop-spotlight > .section-heading {
    margin-bottom: var(--space-2);
  }

  .spotlight-copy {
    margin-inline: auto;
    max-width: 58ch;
    margin-bottom: var(--space-6);
  }

  .spotlight-card {
    border: 1px solid var(--color-card-border-soft);
    border-radius: var(--radius-lg);
    background: var(--color-surface-card);
    box-shadow: var(--shadow-soft);
    color: var(--color-card-text);
    display: grid;
    grid-template-columns: 1fr;
    overflow: hidden;
  }

  .spotlight-image-wrap {
    overflow: hidden;
    max-height: 320px;
  }

  .spotlight-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .spotlight-body {
    padding: var(--space-6) var(--space-6) var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  @media (prefers-reduced-motion: no-preference) {
    .spotlight-card {
      transition: transform 320ms ease, box-shadow 320ms ease, border-color 320ms ease;
    }

    .spotlight-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-glow);
      border-color: var(--color-card-border-strong);
    }

  }

  :root[data-theme='dark'] .spotlight-card {
    border-color: var(--color-border-soft);
    background: var(--color-surface);
  }

  :root[data-theme='dark'] .spotlight-card:hover {
    border-color: var(--color-border);
  }

  .spotlight-category {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    background: color-mix(in oklab, var(--color-accent) 6%, transparent);
    border-radius: var(--radius-pill);
    padding: 0.15rem 0.65rem;
    margin-bottom: var(--space-3);
  }

  :root[data-theme='dark'] .spotlight-category {
    color: var(--color-text-muted);
    border-color: var(--color-border);
  }

  .spotlight-name {
    margin: 0 0 var(--space-3);
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.7rem, 3.5vw, 2.4rem);
    line-height: 1.15;
    color: var(--color-card-text);
  }

  :root[data-theme='dark'] .spotlight-name {
    color: var(--color-text-strong);
  }

  .spotlight-desc {
    margin: 0;
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-card-text-muted);
  }

  :root[data-theme='dark'] .spotlight-desc {
    color: var(--color-text-muted);
  }

  .spotlight-footer {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: var(--space-4);
    flex-wrap: wrap;
    border-top: 1px solid color-mix(in oklab, var(--color-text-strong) 12%, transparent);
    padding-top: var(--space-4);
  }

  :root[data-theme='dark'] .spotlight-footer {
    border-top-color: var(--color-border-soft);
  }

  .spotlight-blurb {
    margin: var(--space-3) 0 0;
    font-size: 0.85rem;
    font-style: italic;
    color: var(--color-text-muted);
  }

  .visit-icon {
    width: 0;
    opacity: 0;
    overflow: hidden;
    flex-shrink: 0;
    margin-inline-start: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    .visit-icon {
      transition: width 220ms ease, opacity 220ms ease, margin-inline-start 220ms ease;
    }
  }

  .spotlight-card:hover .visit-icon,
  .spotlight-card:focus-visible .visit-icon {
    width: 14px;
    opacity: 1;
    margin-inline-start: var(--space-1);
  }

  @media (min-width: 48rem) {
    .spotlight-card {
      grid-template-columns: 340px 1fr;
    }

    .spotlight-image-wrap {
      max-height: none;
    }

    .spotlight-body {
      padding: var(--space-8);
    }
  }

  @media (min-width: 64rem) {
    .spotlight-card {
      grid-template-columns: 400px 1fr;
    }
  }

  /* Ghost button inside a light-mode card: hover would otherwise turn the same
     lavender as the card surface. Keep it white; signal hover via border + shadow only. */
  :root:not([data-theme='dark']) .spotlight-footer :global(.button-ghost:hover) {
    background: var(--color-surface);
    border-color: var(--color-accent);
  }
</style>
