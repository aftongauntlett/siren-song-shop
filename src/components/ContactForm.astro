---
const contactStatus = Astro.url.searchParams.get('contact');
---

<section id="contact-form" aria-labelledby="contact-heading" class="contact">
  <div id="contact-status" class="status" role="status" aria-live="polite" hidden>
    <p id="contact-status-message"></p>
  </div>

  {contactStatus === 'sent' && (
    <div class="status status--success" role="alert">
      <p>Your message has been sent — we'll review it personally and be in touch soon.</p>
    </div>
  )}

  {contactStatus === 'error' && (
    <div class="status status--error" role="alert">
      <p>Something went wrong sending your message. Please try again in a moment.</p>
    </div>
  )}

  {contactStatus !== 'sent' && (
    <form action="/api/contact" method="post">
      {/* Honeypot — visually hidden, must remain empty */}
      <div class="hp-field" aria-hidden="true">
        <label for="project-url">
          Leave this blank
          <input
            id="project-url"
            name="project-url"
            type="text"
            autocomplete="off"
            tabindex="-1"
          />
        </label>
      </div>

      <input type="hidden" id="form-started-at" name="form-started-at" value="" />

      <div class="field">
        <label for="name">
          Name
          <input
            id="name"
            name="name"
            type="text"
            required
            autocomplete="name"
            maxlength="120"
          />
        </label>
      </div>

      <div class="field">
        <label for="email">
          Email
          <input
            id="email"
            name="email"
            type="email"
            required
            autocomplete="email"
            maxlength="254"
          />
        </label>
      </div>

      <div class="field">
        <fieldset class="reason-field">
          <legend class="reason-legend">Reason for message</legend>

          <details class="select" id="reason-select">
            <summary class="select-trigger">
              <span class="select-display">Select a reason…</span>
              <svg class="select-chevron" width="12" height="8" viewBox="0 0 12 8" fill="none" aria-hidden="true">
                <path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </summary>

            <ul class="select-options">
              <li>
                <label class="option-label">
                  <input type="radio" name="reason" value="request_add" class="option-radio" required />
                  Request your shop be added
                </label>
              </li>
              <li>
                <label class="option-label">
                  <input type="radio" name="reason" value="suggest_resource" class="option-radio" />
                  Suggest a shop or resource
                </label>
              </li>
              <li>
                <label class="option-label">
                  <input type="radio" name="reason" value="request_remove" class="option-radio" />
                  Request a shop be removed / report a shop
                </label>
              </li>
              <li>
                <label class="option-label">
                  <input type="radio" name="reason" value="general" class="option-radio" />
                  General question
                </label>
              </li>
            </ul>
          </details>
        </fieldset>
      </div>

      <div class="field">
        <label for="message">
          Message
          <textarea
            id="message"
            name="message"
            rows="6"
            required
            minlength="10"
            maxlength="5000"
          ></textarea>
        </label>
      </div>

      <fieldset class="url-field" id="url-fieldset">
        <legend class="url-legend">
          URLs
          <span class="url-optional">(optional)</span>
        </legend>
        <div class="url-list" id="url-list">
          <div class="url-row">
            <input
              class="url-input"
              id="url-0"
              name="urls[]"
              type="url"
              aria-label="URL 1"
              autocomplete="url"
              maxlength="2048"
              placeholder="https://"
            />
          </div>
        </div>
        <button type="button" id="url-add" class="url-add-btn" aria-label="Add another URL">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M7 1v12M1 7h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
          </svg>
          Add URL
        </button>
      </fieldset>

      <button type="submit" id="contact-submit">Send message</button>
    </form>
  )}
</section>

<script>
  const startedAtField = document.getElementById('form-started-at') as HTMLInputElement | null;
  if (startedAtField) startedAtField.value = String(Date.now());

  // Custom select
  const sel = document.getElementById('reason-select') as HTMLDetailsElement | null;
  const display = sel?.querySelector('.select-display');
  const radios = document.querySelectorAll<HTMLInputElement>('input[name="reason"]');
  const form = document.querySelector<HTMLFormElement>('form[action="/api/contact"]');
  const submitButton = document.getElementById('contact-submit') as HTMLButtonElement | null;
  const statusEl = document.getElementById('contact-status') as HTMLDivElement | null;
  const statusMessageEl = document.getElementById('contact-status-message') as HTMLParagraphElement | null;

  const showStatus = (message: string, kind: 'success' | 'error') => {
    if (!statusEl || !statusMessageEl) return;
    statusEl.hidden = false;
    statusEl.classList.remove('status--success', 'status--error');
    statusEl.classList.add(kind === 'success' ? 'status--success' : 'status--error');
    statusMessageEl.textContent = message;
    statusEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  };

  const syncReasonValidity = () => {
    const selected = Array.from(radios).some((radio) => radio.checked);
    for (const radio of radios) {
      radio.setCustomValidity(selected ? '' : 'Please choose a reason for your message.');
    }
  };

  const setFormEnabled = (enabled: boolean) => {
    if (!form) return;
    for (const control of Array.from(form.elements)) {
      if (
        control instanceof HTMLInputElement ||
        control instanceof HTMLTextAreaElement ||
        control instanceof HTMLButtonElement ||
        control instanceof HTMLSelectElement
      ) {
        control.disabled = !enabled;
      }
    }
  };

  syncReasonValidity();

  for (const radio of radios) {
    radio.addEventListener('change', () => {
      if (display) {
        const labelEl = radio.closest('label');
        const text = labelEl
          ? Array.from(labelEl.childNodes)
              .filter((n) => n.nodeType === Node.TEXT_NODE)
              .map((n) => n.textContent?.trim())
              .find(Boolean)
          : undefined;
        display.textContent = text ?? radio.value;
      }
      if (sel) sel.open = false;
      syncReasonValidity();
    });
  }

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    syncReasonValidity();
    if (!form || !form.reportValidity()) return;

    if (submitButton) {
      submitButton.disabled = true;
      submitButton.textContent = 'Sending...';
    }

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: {
          'x-contact-ajax': '1',
          Accept: 'application/json',
        },
      });

      if (!response.ok) {
        throw new Error(`request_failed_${response.status}`);
      }

      showStatus('Thanks, we will be in touch!', 'success');
      setFormEnabled(false);
      if (submitButton) {
        submitButton.textContent = 'Message sent';
      }
    } catch {
      showStatus('Something went wrong sending your message. Please try again in a moment.', 'error');
      if (submitButton) {
        submitButton.disabled = false;
        submitButton.textContent = 'Send message';
      }
    }
  });

  document.addEventListener('click', (e) => {
    if (sel && !sel.contains(e.target as Node)) sel.open = false;
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && sel?.open) sel.open = false;
  });

  // Dynamic URL fields
  const urlList = document.getElementById('url-list');
  const urlAddBtn = document.getElementById('url-add');
  let urlCount = 1;

  urlAddBtn?.addEventListener('click', () => {
    const index = urlCount++;
    const row = document.createElement('div');
    row.className = 'url-row';

    const input = document.createElement('input');
    input.id = `url-${index}`;
    input.className = 'url-input';
    input.name = 'urls[]';
    input.type = 'url';
    input.setAttribute('aria-label', `URL ${index + 1}`);
    input.setAttribute('autocomplete', 'url');
    input.maxLength = 2048;
    input.placeholder = 'https://';

    const removeBtn = document.createElement('button');
    removeBtn.type = 'button';
    removeBtn.className = 'url-remove-btn';
    removeBtn.setAttribute('aria-label', `Remove URL ${index + 1}`);
    removeBtn.innerHTML = `<svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M1 1l10 10M11 1L1 11" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/></svg>`;
    removeBtn.addEventListener('click', () => {
      row.remove();
    });

    row.appendChild(input);
    row.appendChild(removeBtn);
    urlList?.appendChild(row);
    input.focus();
  });
</script>

<style>
  .contact {
    padding: 0;
  }

  form {
    display: grid;
    gap: var(--space-5);
  }

  .field {
    display: grid;
    gap: var(--space-2);
  }

  label {
    display: grid;
    gap: var(--space-2);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-text);
  }

  input:not(.option-radio),
  textarea {
    width: 100%;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-text);
    padding: var(--space-3);
    font: inherit;
    font-size: 1rem;
    transition: border-color 200ms ease, box-shadow 200ms ease;
  }

  input:not(.option-radio):focus-visible,
  textarea:focus-visible {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: var(--focus-ring);
  }

  input:not(.option-radio):-webkit-autofill,
  input:not(.option-radio):-webkit-autofill:hover,
  input:not(.option-radio):-webkit-autofill:focus,
  textarea:-webkit-autofill,
  textarea:-webkit-autofill:hover,
  textarea:-webkit-autofill:focus,
  :global(.url-input:-webkit-autofill),
  :global(.url-input:-webkit-autofill:hover),
  :global(.url-input:-webkit-autofill:focus) {
    -webkit-text-fill-color: var(--color-text);
    caret-color: var(--color-text);
    -webkit-box-shadow: 0 0 0 1000px var(--color-surface) inset;
    box-shadow: 0 0 0 1000px var(--color-surface) inset;
    border: 1px solid var(--color-border);
    transition: background-color 9999s ease-in-out 0s;
  }

  input:not(.option-radio):-moz-autofill,
  textarea:-moz-autofill,
  :global(.url-input:-moz-autofill) {
    color: var(--color-text);
    box-shadow: 0 0 0 1000px var(--color-surface) inset;
  }

  textarea {
    resize: vertical;
    min-height: 8rem;
  }

  .url-field {
    border: none;
    padding: 0;
    margin: 0;
    min-width: 0;
    display: grid;
    gap: var(--space-3);
  }

  .url-legend {
    float: left;
    width: 100%;
    padding: 0;
    margin-bottom: var(--space-3);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-text);
  }

  .url-optional {
    font-weight: 400;
    color: var(--color-text-muted);
    font-size: 0.8rem;
    margin-left: var(--space-1);
  }

  .url-list {
    clear: both;
    display: grid;
    gap: var(--space-2);
  }

  :global(.url-row) {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: var(--space-2);
  }

  :global(.url-input) {
    width: 100%;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-text);
    padding: var(--space-3);
    font: inherit;
    font-size: 1rem;
    transition: border-color 200ms ease, box-shadow 200ms ease;
  }

  :global(.url-input:focus-visible) {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: var(--focus-ring);
  }

  :global(.url-row .url-input) {
    grid-column: 1;
  }

  :global(.url-remove-btn) {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--color-text-muted);
    padding: var(--space-2);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: color 150ms ease, border-color 150ms ease, background 150ms ease;
    flex-shrink: 0;
  }

  :global(.url-remove-btn:hover) {
    color: var(--color-danger);
    border-color: var(--color-danger);
    background: color-mix(in oklab, var(--color-danger) 8%, transparent);
  }

  :global(.url-remove-btn:focus-visible) {
    outline: none;
    box-shadow: var(--focus-ring);
  }

  .url-add-btn {
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--color-text-muted);
    font: inherit;
    font-size: 0.875rem;
    padding: var(--space-2) var(--space-4);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    width: fit-content;
    cursor: pointer;
    transition: color 150ms ease, border-color 150ms ease, background 150ms ease;
  }

  .url-add-btn:hover {
    color: var(--color-accent-strong);
    border-color: var(--color-accent);
    background: var(--color-accent-soft);
  }

  .url-add-btn:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
  }

  button[type="submit"] {
    border: 0;
    border-radius: var(--radius-sm);
    background: var(--color-accent);
    color: var(--color-on-accent);
    font: inherit;
    font-weight: 700;
    padding: var(--space-3) var(--space-6);
    width: fit-content;
    margin-left: auto;
    cursor: pointer;
    transition: background 200ms ease, box-shadow 200ms ease, transform 200ms ease;
  }

  @media (prefers-reduced-motion: no-preference) {
    button[type="submit"]:hover {
      background: var(--color-accent-strong);
      box-shadow: var(--shadow-button-primary);
      transform: translateY(-1px);
    }
  }

  button[type="submit"]:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
  }

  .status {
    padding: var(--space-4);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-6);
  }

  .status p {
    margin: 0;
    font-weight: 600;
  }

  .status--success {
    background: color-mix(in oklab, var(--color-accent-pop) 12%, transparent);
    border: 1px solid var(--color-accent-pop);
    color: var(--color-accent-pop);
  }

  .status--error {
    background: color-mix(in oklab, var(--color-danger) 10%, transparent);
    border: 1px solid var(--color-danger);
    color: var(--color-danger);
  }

  /* ── Custom select ── */

  .reason-field {
    border: none;
    padding: 0;
    margin: 0;
    min-width: 0;
  }

  .reason-legend {
    float: left;
    width: 100%;
    padding: 0;
    margin-bottom: var(--space-2);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-text);
  }

  .select {
    position: relative;
    clear: both;
  }

  .select-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-text);
    padding: var(--space-3);
    font: inherit;
    font-size: 1rem;
    text-align: left;
    cursor: pointer;
    list-style: none;
    transition: border-color 200ms ease, box-shadow 200ms ease;
  }

  /* Remove the native disclosure triangle */
  .select-trigger::-webkit-details-marker { display: none; }
  .select-trigger::marker { content: none; }

  .select-trigger:focus-visible {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: var(--focus-ring);
  }

  .select[open] .select-trigger {
    border-color: var(--color-accent);
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
    box-shadow: var(--focus-ring);
  }

  .select-chevron {
    flex-shrink: 0;
    color: var(--color-accent);
    transition: transform 200ms ease;
  }

  .select[open] .select-chevron {
    transform: rotate(180deg);
  }

  .select-options {
    position: absolute;
    left: 0;
    right: 0;
    z-index: 10;
    list-style: none;
    margin: 0;
    padding: var(--space-2);
    background: var(--color-surface);
    border: 1px solid var(--color-accent);
    border-top: none;
    border-bottom-left-radius: var(--radius-sm);
    border-bottom-right-radius: var(--radius-sm);
    box-shadow: var(--shadow-soft);
  }

  .option-label {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-weight: 400;
    font-size: 1rem;
    color: var(--color-text);
    transition: background 150ms ease, color 150ms ease;
  }

  .option-label::after {
    content: '';
    margin-left: auto;
    width: 1.25rem;
    flex-shrink: 0;
    text-align: center;
    font-weight: 700;
  }

  .option-label:hover {
    background: var(--color-accent-soft);
    color: var(--color-text-strong);
  }

  .option-label:has(.option-radio:checked) {
    background: var(--color-accent-soft);
    color: var(--color-accent-strong);
    font-weight: 600;
  }

  .option-label:has(.option-radio:checked)::after {
    content: '✓';
    color: var(--color-accent);
  }

  .option-label:has(.option-radio:focus-visible) {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
  }

  /* Screen-reader-only hidden radio inputs (no !important — excluded from field input rule above) */
  .option-radio {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  /* ── Honeypot ── */
  .hp-field {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
    opacity: 0;
  }
</style>
