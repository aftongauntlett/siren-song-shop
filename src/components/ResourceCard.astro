---
interface Props {
  name: string;
  url: string;
  description: string;
  featured?: boolean;
}

const { name, url, description, featured = false } = Astro.props;

const displayUrl = new URL(url).hostname.replace(/^www\./, '');
---

<article class:list={['resource-card', { 'resource-card--featured': featured }]}>
  <div class="resource-card-body">
    <h3 class="resource-name">{name}</h3>
    <p class="resource-description">{description}</p>
  </div>
  <a
    class="resource-link"
    href={url}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={`Visit ${name} (opens in new tab)`}
  >
    {displayUrl}
    <span class="resource-link-arrow" aria-hidden="true">↗</span>
  </a>
</article>

<style>
  .resource-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-lg);
    background: var(--color-surface-card);
    box-shadow: var(--shadow-soft);
    transition: box-shadow 320ms ease, border-color 320ms ease, transform 320ms ease;
  }

  .resource-card:hover {
    box-shadow: var(--shadow-glow);
    border-color: var(--color-border);
    transform: translateY(-2px);
  }

  .resource-card--featured {
    border-color: var(--color-accent-soft);
    background: color-mix(in oklab, var(--color-surface-card) 90%, var(--color-accent-soft));
  }

  .resource-card-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .resource-name {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text-strong);
  }

  .resource-description {
    margin: 0;
    font-size: 0.925rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .resource-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-accent-teal);
    text-decoration: none;
    align-self: flex-start;
    transition: color 200ms ease, gap 200ms ease;
  }

  .resource-link:hover {
    color: var(--color-accent);
    gap: var(--space-2);
  }

  .resource-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: var(--radius-sm, 2px);
  }

  .resource-link-arrow {
    font-style: normal;
  }
</style>
