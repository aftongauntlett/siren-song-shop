---
import ButtonLink from './ButtonLink.astro';
---

<section aria-labelledby="purpose-heading" class="purpose">
  <p class="purpose-kicker" data-reveal>our story</p>
  <h2 id="purpose-heading" class="purpose-heading" data-reveal data-reveal-delay="1">Why This Exists</h2>
  <div class="purpose-quote-wrap" data-reveal data-reveal-delay="2">
    <p class="purpose-quote">Two lifelong friends kept running into the same wall — where do you actually find things worth supporting?</p>
  </div>
  <div class="purpose-body" data-reveal data-reveal-delay="2">
    <p>
      So we built Siren Song Shop — a small, carefully curated space, where we share the shops, makers, and products we love. We focus on highlighting independent and underrepresented creators, and we prioritize featuring businesses that support vegan products.
    </p>
    <p>
      We hope it's useful to many — but if it helps even one person connect with a great local shop, find a gift that really hits the mark, or discover a maker they love, then that's more than enough for us.
    </p>
  </div>
  <div class="purpose-cta" data-reveal data-reveal-delay="3">
    <ButtonLink href="/about" variant="primary">Read our full story</ButtonLink>
  </div>
</section>

<style>
  .purpose {
    text-align: center;
    max-width: 56ch;
    margin-inline: auto;
  }

  .purpose-kicker {
    margin: 0 0 var(--space-3);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    font-weight: 700;
    font-size: 0.75rem;
  }

  .purpose-heading {
    margin: 0 0 var(--space-6);
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.9rem, 4vw, 2.8rem);
    line-height: 1.2;
    color: var(--color-text-strong);
  }

  .purpose-quote-wrap {
    margin-bottom: var(--space-8);
  }

  .purpose-quote-wrap::before {
    content: '\201C';
    display: block;
    font-family: var(--font-display);
    font-size: 3.5rem;
    line-height: 0.8;
    color: color-mix(in oklab, var(--color-accent) 45%, transparent);
    margin-bottom: var(--space-2);
  }

  .purpose-quote {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.1rem, 2.5vw, 1.35rem);
    line-height: 1.6;
    color: var(--color-text);
    margin: 0;
  }

  .purpose-body p {
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.8;
    font-size: 1rem;
  }

  .purpose-body p + p {
    margin-top: var(--space-4);
  }

  .purpose-cta {
    margin-top: var(--space-8);
    display: flex;
    justify-content: center;
  }
</style>

