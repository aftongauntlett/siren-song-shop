---
import ButtonLink from './ButtonLink.astro';
import WaterCanvas from './WaterCanvas.tsx';
---

<header class="site-header">
  <WaterCanvas client:load />
  <div class="container inner">
    <p class="kicker">Siren Song</p>
    <h1>A calm, trust-first space for things worth sharing.</h1>
    <p class="intro">
      Handpicked artists, makers, books, tea, and gift ideas — shaped with genuine care and an editorial voice you can trust.
    </p>
    <div class="hero-actions">
      <ButtonLink href="/guides">Explore Early Guides</ButtonLink>
      <ButtonLink href="/guides" variant="ghost">See the Mood</ButtonLink>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: relative;
    overflow: hidden;
    padding: var(--space-16) 0 var(--space-10);
    border-bottom: 1px solid var(--color-border-soft);
  }

  .inner {
    position: relative;
    z-index: 1;
  }

  .kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent-teal);
    font-weight: 600;
    font-size: 0.8rem;
  }

  h1 {
    margin: var(--space-2) 0 var(--space-4);
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 1.15;
    color: var(--color-text-strong);
    max-width: 18ch;
    font-size: clamp(2rem, 5.5vw, 3.8rem);
  }

  .intro {
    max-width: 56ch;
    margin: 0;
    color: var(--color-text-muted);
    font-weight: 400;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }
</style>
