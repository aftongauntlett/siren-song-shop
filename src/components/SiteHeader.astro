---
import ButtonLink from './ButtonLink.astro';
---

<header class="site-header">
  <div class="container hero-content">
    <p class="kicker">Curated with care</p>
    <h1>A calm, trust-first space for things worth sharing.</h1>
    <p class="intro">
      Handpicked artists, makers, books, tea, and gift ideas — shaped with genuine care and an editorial voice you can trust.
    </p>
    <div class="hero-actions">
      <ButtonLink href="/shop">Browse Shops</ButtonLink>
      <ButtonLink href="/get-involved" variant="ghost">Get Involved</ButtonLink>
    </div>
  </div>
</header>

<style>
  .site-header {
    padding: var(--space-20) 0;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-4);
  }

  .kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent-teal);
    font-weight: 600;
    font-size: 0.8rem;
  }

  h1 {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 1.15;
    color: var(--color-text-strong);
    font-size: clamp(2.2rem, 5.5vw, 4rem);
    max-width: 22ch;
  }

  .intro {
    margin: 0;
    color: var(--color-text-muted);
    font-weight: 400;
    max-width: 52ch;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }
</style>
