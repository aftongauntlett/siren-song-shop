---
import type { RecommendationCategory } from '../lib/schemas/recommendation';

interface Props {
  title: string;
  category: RecommendationCategory;
  excerpt: string;
  href: string;
}

const { title, category, excerpt, href } = Astro.props;
---

<article class="card">
  <p class="category">{category}</p>
  <h2>{title}</h2>
  <p>{excerpt}</p>
  <a href={href} target="_blank" rel="noreferrer">Visit recommendation</a>
</article>

<style>
  .card {
    padding: var(--space-6);
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    display: grid;
    gap: var(--space-3);
    transition: box-shadow 320ms ease, border-color 320ms ease, transform 320ms ease;
  }

  .card:hover {
    box-shadow: var(--shadow-glow);
    border-color: var(--color-border);
    transform: translateY(-2px);
  }

  .category {
    margin: 0;
    text-transform: capitalize;
    color: var(--color-accent-teal);
    font-size: 0.875rem;
    font-weight: 600;
  }

  h2,
  p {
    margin: 0;
  }
</style>
