---
const navLinks = [
  { href: '/shop', label: 'Browse Shops' },
  { href: '/get-involved', label: 'Get Involved' },
  { href: '/local', label: 'Local Gems' },
] as const;

const currentPath = Astro.url.pathname;
---

<nav class="site-nav" aria-label="Primary navigation">
  <div class="container nav-inner">
    <a href="/" class="brand" data-astro-prefetch>Siren Song Shop</a>
    <button
      class="nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="primary-navigation-list"
      aria-label="Open menu"
    >
      <span class="nav-toggle-lines" aria-hidden="true">
        <span class="nav-toggle-line"></span>
        <span class="nav-toggle-line"></span>
        <span class="nav-toggle-line"></span>
      </span>
      <span class="nav-toggle-text">Menu</span>
    </button>
    <ul class="nav-links" id="primary-navigation-list">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            data-astro-prefetch
            class:list={['nav-link', { 'nav-link--active': currentPath.startsWith(href) }]}
            aria-current={currentPath.startsWith(href) ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const w = window as Window & {
    __sirenNavHooksBound?: boolean;
    __sirenNavScrollHandler?: () => void;
    __sirenNavResizeHandler?: () => void;
  };

  const initializeSiteNav = () => {
    const nav = document.querySelector<HTMLElement>('.site-nav');
    if (!nav) return;

    const navToggle = nav.querySelector<HTMLButtonElement>('.nav-toggle');
    const navLinkItems = nav.querySelectorAll<HTMLAnchorElement>('.nav-link');

    const setMenuOpenState = (isOpen: boolean) => {
      if (!navToggle) return;
      nav.dataset.menuOpen = isOpen ? 'true' : 'false';
      navToggle.setAttribute('aria-expanded', String(isOpen));
      navToggle.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
    };

    setMenuOpenState(false);

    if (navToggle && navToggle.dataset.navToggleBound !== 'true') {
      navToggle.addEventListener('click', () => {
        setMenuOpenState(nav.dataset.menuOpen !== 'true');
      });
      navToggle.dataset.navToggleBound = 'true';
    }

    navLinkItems.forEach((link) => {
      if (link.dataset.navLinkBound === 'true') return;
      link.addEventListener('click', () => {
        if (window.matchMedia('(max-width: 47.99rem)').matches) {
          setMenuOpenState(false);
        }
      });
      link.dataset.navLinkBound = 'true';
    });

    nav.classList.toggle('site-nav--scrolled', window.scrollY > 8);
  };

  if (!w.__sirenNavHooksBound) {
    w.__sirenNavScrollHandler = () => {
      document.querySelector<HTMLElement>('.site-nav')?.classList.toggle('site-nav--scrolled', window.scrollY > 8);
    };

    w.__sirenNavResizeHandler = () => {
      if (!window.matchMedia('(min-width: 48rem)').matches) return;
      const nav = document.querySelector<HTMLElement>('.site-nav');
      const navToggle = nav?.querySelector<HTMLButtonElement>('.nav-toggle');
      if (!nav || !navToggle) return;
      nav.dataset.menuOpen = 'false';
      navToggle.setAttribute('aria-expanded', 'false');
      navToggle.setAttribute('aria-label', 'Open menu');
    };

    window.addEventListener('scroll', w.__sirenNavScrollHandler, { passive: true });
    window.addEventListener('resize', w.__sirenNavResizeHandler, { passive: true });
    document.addEventListener('astro:page-load', initializeSiteNav);
    w.__sirenNavHooksBound = true;
  }

  initializeSiteNav();
</script>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    background: color-mix(in srgb, var(--color-bg) 75%, transparent);
    border-bottom: 1px solid var(--color-border-soft);
    transition: background-color 200ms ease, backdrop-filter 200ms ease, box-shadow 200ms ease;
  }

  .site-nav.site-nav--scrolled {
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    box-shadow: var(--shadow-nav-scrolled);
  }



  .nav-inner {
    position: relative;
    min-height: 4rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .brand {
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    font-size: 0.875rem;
    color: var(--color-text-strong);
    flex-shrink: 0;
  }

  .brand:hover {
    color: var(--color-accent);
  }

  .nav-toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    border: 1px solid var(--color-border-soft);
    background: color-mix(in oklab, var(--color-surface) 86%, transparent);
    color: var(--color-text-strong);
    border-radius: var(--radius-md);
    padding: 0.45rem 0.75rem;
    font: inherit;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    cursor: pointer;
  }

  .nav-toggle-lines {
    display: inline-flex;
    flex-direction: column;
    gap: 3px;
  }

  .nav-toggle-line {
    display: block;
    width: 1rem;
    height: 2px;
    border-radius: 2px;
    background: currentColor;
  }

  .nav-toggle-text {
    line-height: 1;
  }

  .nav-links {
    position: absolute;
    top: calc(100% + 1px);
    left: 0;
    right: 0;
    display: none;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    justify-content: flex-start;
    margin: 0;
    padding: var(--space-3) var(--space-4) var(--space-4);
    list-style: none;
    background: color-mix(in srgb, var(--color-bg) 94%, transparent);
    border-bottom: 1px solid var(--color-border-soft);
    box-shadow: var(--shadow-menu-dark);
  }

  .site-nav[data-menu-open='true'] .nav-links {
    display: flex;
  }

  .nav-link {
    text-decoration: none;
    color: var(--color-text-muted);
    font-size: 0.95rem;
    font-weight: 500;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    border: 1px solid transparent;
    display: block;
    text-align: center;
    transition: color 180ms ease, background-color 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  .nav-link:hover {
    color: var(--color-text-strong);
    background: var(--color-surface-strong);
  }

  .nav-link--active {
    color: var(--color-text-strong);
    font-weight: 600;
    background: var(--color-surface-strong);
    border-color: color-mix(in oklab, var(--color-accent-soft) 70%, var(--color-border-soft));
    box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--color-accent) 25%, transparent);
  }

  .nav-link--active:hover {
    color: var(--color-text-strong);
    background: var(--color-surface-strong);
  }

  @media (min-width: 48rem) {
    .nav-toggle {
      display: none;
    }

    .nav-links {
      position: static;
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: var(--space-1);
      justify-content: flex-end;
      margin: 0;
      padding: 0;
      border-bottom: 0;
      box-shadow: none;
      background: transparent;
    }

    .nav-link {
      display: inline-block;
      font-size: 0.9rem;
    }
  }
</style>