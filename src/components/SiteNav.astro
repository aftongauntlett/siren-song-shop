---
const navLinks = [
  { href: '/recommendations', label: 'Recommendations' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
] as const;

const currentPath = Astro.url.pathname;
---

<nav class="site-nav" aria-label="Primary navigation">
  <div class="container nav-inner">
    <a href="/" class="brand">Siren Song Shop</a>
    <ul class="nav-links">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={['nav-link', { 'nav-link--active': currentPath.startsWith(href) }]}
            aria-current={currentPath.startsWith(href) ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(8px);
    background: color-mix(in oklab, var(--color-bg) 85%, transparent);
    border-bottom: 1px solid var(--color-border-soft);
  }

  .nav-inner {
    min-height: 4rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .brand {
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    font-size: 0.875rem;
    color: var(--color-text-strong);
    flex-shrink: 0;
  }

  .brand:hover {
    color: var(--color-accent);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    flex-wrap: wrap;
    justify-content: flex-end;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .nav-link {
    text-decoration: none;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    font-weight: 500;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    transition: color 180ms ease, background-color 180ms ease;
  }

  .nav-link:hover {
    color: var(--color-text-strong);
    background: var(--color-surface-strong);
  }

  .nav-link--active {
    color: var(--color-accent);
    font-weight: 600;
  }

  .nav-link--active:hover {
    color: var(--color-accent-strong);
  }
</style>