---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  href: string;
  cta: string;
  external?: boolean;
}

const { eyebrow, title, description, href, cta, external = false } = Astro.props as Props;
---

<a
  class="feature-card"
  href={href}
  target={external ? '_blank' : '_self'}
  {...(external ? { rel: 'noopener noreferrer' } : {})}
  aria-label={`${title}: ${cta}${external ? ' (opens in new tab)' : ''}`}
>
  <div class="card-icon-wrap" aria-hidden="true">
    <slot name="icon" />
  </div>
  <p class="eyebrow">{eyebrow}</p>
  <h3>{title}</h3>
  <p>{description}</p>
  <span class="feature-cta" aria-hidden="true">
    {cta}
    {external && (
      <svg class="ext-icon" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M6 3h7v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M10 6L3 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    )}
  </span>
</a>

<style>
  .feature-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-decoration: none;
    gap: var(--space-3);
    height: 100%;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-card-border-soft);
    background: var(--color-surface-card);
    box-shadow: var(--shadow-soft);
    padding: var(--space-6) var(--space-5);
    transition: box-shadow 320ms ease, border-color 320ms ease, transform 320ms ease, background-color 320ms ease;
    color: var(--color-on-accent);
  }

  .feature-card:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring), var(--shadow-glow);
  }

  :root[data-theme='dark'] .feature-card {
    border-color: var(--color-border-soft);
  }

  .feature-card:hover {
    box-shadow: var(--shadow-glow);
    border-color: var(--color-card-border-strong);
    transform: translateY(-2px);
  }

  :root:not([data-theme='dark']) .feature-card:hover {
    background: color-mix(in oklab, var(--color-surface-card) 86%, black 14%);
  }

  :root[data-theme='dark'] .feature-card:hover {
    border-color: var(--color-border);
  }

  .feature-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    padding: 0.4rem 0.9rem;
    font-size: 0.85rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-on-accent);
  }

  :root:not([data-theme='dark']) .feature-cta {
    background: var(--color-menu-option-hover-bg);
    border-color: var(--color-menu-option-active-border);
    color: var(--color-on-accent);
  }

  :root:not([data-theme='dark']) .feature-card:hover .feature-cta {
    background: var(--color-menu-option-active-bg);
    border-color: color-mix(in oklab, var(--color-on-accent) 70%, transparent);
    box-shadow: var(--shadow-card-cta);
  }

  :root[data-theme='dark'] .feature-cta {
    color: var(--color-accent);
    background: color-mix(in oklab, var(--color-accent-soft) 38%, transparent);
    border-color: var(--color-border);
  }

  :root[data-theme='dark'] .feature-card:hover .feature-cta {
    color: var(--color-accent-pop);
    border-color: var(--color-border);
    background: color-mix(in oklab, var(--color-accent-soft) 52%, transparent);
  }

  .card-icon-wrap {
    display: flex;
    width: 3.25rem;
    height: 3.25rem;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: color-mix(in oklab, var(--color-on-accent) 18%, transparent);
    color: var(--color-on-accent);
    transition: color 200ms ease;
  }

  :root[data-theme='dark'] .card-icon-wrap {
    background: color-mix(in oklab, var(--color-accent-soft) 60%, transparent);
    color: var(--color-accent);
  }

  .feature-card:hover .card-icon-wrap {
    color: var(--color-hover-warm);
  }

  :root[data-theme='dark'] .feature-card:hover .card-icon-wrap {
    color: var(--color-teal);
  }

  @media (prefers-reduced-motion: no-preference) {
    .feature-card:hover .card-icon-wrap > :global(svg) {
      animation: wiggle 420ms ease;
    }
  }

  .eyebrow {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-on-accent);
    font-size: 0.75rem;
    font-weight: 600;
  }

  :root[data-theme='dark'] .eyebrow {
    color: var(--color-accent-pop);
  }

  h3,
  p {
    margin: 0;
  }

  h3 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.35rem;
    line-height: 1.25;
    color: var(--color-on-accent);
  }

  :root[data-theme='dark'] h3 {
    color: var(--color-text-strong);
  }

  p:not(.eyebrow) {
    color: var(--color-on-accent);
    flex: 1;
  }

  :root[data-theme='dark'] p:not(.eyebrow) {
    color: var(--color-text-muted);
  }

  .ext-icon {
    width: 0;
    opacity: 0;
    overflow: hidden;
    flex-shrink: 0;
    margin-inline-start: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    .ext-icon {
      transition: width 220ms ease, opacity 220ms ease, margin-inline-start 220ms ease;
    }
  }

  .feature-card:hover .ext-icon,
  .feature-card:focus-visible .ext-icon {
    width: 14px;
    opacity: 1;
    margin-inline-start: var(--space-1);
  }
</style>