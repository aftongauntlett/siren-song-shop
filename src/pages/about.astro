---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ButtonLink from '../components/ButtonLink.astro';
import CatLottie from '../components/CatLottie.tsx';
import wallArtImg from '../assets/wall-art.jpg';
---

<BaseLayout title="About | Siren Song Shop" description="The story behind Siren Song Shop — a trust-first recommendation platform for things genuinely worth sharing.">
  <SiteNav />
  <main id="main-content" class="container">
    <section class="page-hero" aria-labelledby="about-heading">
      <p class="kicker">Our Story</p>
      <h1 id="about-heading">A little bit about us</h1>
      <p class="intro">
        Siren Song Shop is a curated space for artists, makers, independent shops, apothecaries, and other delightful discoveries — with every pick personally vetted.
      </p>
    </section>

    <section aria-labelledby="mission-heading" class="content-section mission-section">
      <h2 id="mission-heading" class="section-heading" data-reveal>What we believe</h2>
      <p class="section-copy" data-reveal data-reveal-delay="1">
        Great recommendations should have a human voice behind them. We do not publish anything
        we would not confidently give to a close friend. No ad clutter, no sponsored placements,
        no pay-to-play ranking. Just honest taste, practical context, and genuine care — and we
        care deeply about keeping this space welcoming so more people can find useful options
        without noise, pressure, or gatekeeping.
      </p>
      <div class="about-media" data-reveal data-reveal-delay="2">
        <div class="about-quote-wrap" data-reveal data-reveal-delay="3">
          <p class="about-quote">
         Our loyalties are to the species and the planet. We speak for Earth. 
          </p>
          <p class="about-quote-author">Carl Sagan</p>
        </div>
        <div class="about-image-block" data-reveal data-reveal-delay="3">
          <div class="about-image-wrap">
            <Image
              src={wallArtImg}
              alt="A wall art portrait in an ornate frame"
              class="about-image"
            />
          </div>
          <p class="about-image-credit">
            Credit:
            <a href="https://instagram.com/anniespratt" target="_blank" rel="noopener noreferrer">Annie Spratt</a>
          </p>
        </div>
      </div>
    </section>

    <section aria-labelledby="process-heading" class="content-section process-section">
      <h2 id="process-heading" class="section-heading" data-reveal>How picks make the list</h2>
      <p class="section-copy" data-reveal data-reveal-delay="1">
        We look for things with a real story behind them. Every recommendation is put through a
        consistent set of checks before it earns a spot here.
      </p>
      <ul class="vetting-grid" data-reveal data-reveal-delay="2">
        <li>Personally vetted</li>
        <li>Independently owned</li>
        <li>Community-operated</li>
        <li>No pay-to-play</li>
        <li>Accountable</li>
        <li>Ethically operated</li>
        <li>Regularly reviewed</li>
        <li>Honest context</li>
      </ul>
      <aside class="suggest-aside" aria-labelledby="suggest-heading" data-reveal data-reveal-delay="3">
        <p class="suggest-eyebrow">Know something we should know?</p>
        <h3 id="suggest-heading" class="suggest-heading">Recommend a shop or resource.</h3>
        <p class="suggest-body">Know a maker, local org, or community resource that belongs here? We review every suggestion personally. You can recommend something you love, flag a resource worth sharing, or request that your own shop be considered for a listing.</p>
        <a class="suggest-link" href="/contact">
          Send us a note
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </aside>
    </section>

    <section aria-labelledby="support-heading" class="content-section support-section" data-reveal>
      <h2 id="support-heading" class="section-heading">Keep the lights on</h2>
      <p class="section-copy">
        Siren Song is free to use and intentionally ad-free, with no paid placements shaping what
        gets featured. If this project has helped you discover something meaningful, a small
        contribution helps cover hosting, upkeep, and the time it takes to keep every
        recommendation thoughtful and up to date.
      </p>
      <div class="support-links">
        <ButtonLink href="https://ko-fi.com/prettyprettyprettygood" target="_blank" rel="noopener noreferrer">Ko-fi</ButtonLink>
        <ButtonLink href="https://paypal.me/aftons" target="_blank" rel="noopener noreferrer" variant="ghost">PayPal</ButtonLink>
      </div>
      <div class="cat-outer" aria-hidden="true">
        <div class="cat-glow">
          <CatLottie client:load src="/cat-loader.lottie" />
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .page-hero {
    padding: var(--space-12) 0 var(--space-8);
  }

  .kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent-pop);
    font-weight: 600;
    font-size: 0.8rem;
  }

  h1 {
    margin: var(--space-2) 0 var(--space-4);
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 1.15;
    color: var(--color-text-strong);
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .intro {
    margin: 0;
    max-width: 72ch;
    font-size: 1.08rem;
    line-height: 1.75;
    color: var(--color-text-muted);
  }

  .about-media {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    margin-top: var(--space-8);
    align-items: center;
  }

  @media (min-width: 48rem) {
    .about-media {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-10);
    }
  }

  .about-quote-wrap {
    padding-top: var(--space-6);
    border-top: 1px solid color-mix(in oklab, var(--color-border) 75%, transparent);
  }

  @media (min-width: 48rem) {
    .about-quote-wrap {
      border-top: none;
      border-right: 1px solid color-mix(in oklab, var(--color-border) 75%, transparent);
      padding-top: 0;
      padding-right: var(--space-10);
    }
  }

  .about-image-block {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .about-image-wrap {
    border-radius: 1.5rem;
    overflow: hidden;
    transition: transform 260ms ease, box-shadow 260ms ease;
    box-shadow:
      0 0 0 1px var(--color-border-soft),
      0 8px 32px rgba(109, 40, 217, 0.22),
      0 0 80px rgba(109, 40, 217, 0.16),
      0 0 120px rgba(13, 148, 136, 0.12);
  }

  :root:not([data-theme='dark']) .about-image-wrap {
    box-shadow: 0 0 0 1px var(--color-border-soft);
  }

  .about-image {
    width: 100%;
    display: block;
    height: auto;
    object-fit: cover;
    object-position: center;
    transition: transform 320ms ease;
  }

  .about-image-credit {
    margin: var(--space-3) 0 0;
    font-size: 0.82rem;
    color: var(--color-text-muted);
    font-style: italic;
    text-align: center;
  }

  .about-image-credit a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklab, var(--color-text-muted) 35%, transparent);
    transition: border-color 180ms ease, opacity 180ms ease;
  }

  .about-image-credit a:hover {
    border-color: color-mix(in oklab, var(--color-accent) 70%, transparent);
    opacity: 1;
  }

  .about-image-credit a:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
    border-bottom-color: transparent;
  }

  @media (prefers-reduced-motion: no-preference) {
    .about-image-wrap:hover {
      transform: scale(1.012);
    }

    .about-image-wrap:hover .about-image {
      transform: scale(1.02);
    }
  }

  .about-quote-wrap {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .about-quote::before {
    content: '\201C';
    display: block;
    font-family: var(--font-display);
    font-size: 2.6rem;
    line-height: 1;
    color: var(--color-text-strong);
    margin-bottom: var(--space-2);
  }

  .about-quote {
    margin: 0;
    font-family: var(--font-handwrite);
    font-weight: 500;
    font-style: normal;
    font-size: clamp(1.6rem, 3.3vw, 2.2rem);
    line-height: 1.6;
    color: var(--color-accent);
  }

  :root[data-theme='dark'] .about-quote {
    color: var(--color-teal);
  }

  .about-quote-author {
    margin: var(--space-3) 0 0;
    color: var(--color-text-strong);
    font-family: var(--font-handwrite);
    font-size: clamp(1rem, 2vw, 1.2rem);
    font-style: normal;
    font-weight: 400;
    text-align: right;
  }

  .about-quote-author::before {
    content: '\2014\00a0';
  }

  .content-section {
    padding: var(--space-12) 0;
    border-top: 1px solid var(--color-border);
  }

  .content-section .section-heading {
    margin-bottom: var(--space-6);
  }

  .mission-section .section-heading,
  .mission-section .section-copy,
  .process-section .section-heading,
  .process-section .section-copy,
  .support-section .section-heading,
  .support-section .section-copy {
    text-align: center;
  }

  .vetting-grid {
    list-style: none;
    margin: var(--space-8) auto 0;
    padding: 0;
    max-width: 72ch;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2) var(--space-3);
  }

  .vetting-grid li {
    display: inline-flex;
    align-items: center;
    border-radius: var(--radius-pill);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text-strong);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    padding: 0.4rem 0.9rem;
  }

  @media (prefers-reduced-motion: no-preference) {
    .vetting-grid li {
      transition: transform 220ms ease, box-shadow 220ms ease, border-color 220ms ease;
    }

    .vetting-grid li:hover {
      transform: translateY(-1px);
      border-color: var(--color-teal);
      box-shadow: 0 8px 20px -16px color-mix(in oklab, var(--color-teal) 65%, transparent);
    }
  }

  .suggest-aside {
    margin-top: var(--space-16);
    margin-inline: auto;
    max-width: 72ch;
    padding: var(--space-8);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border-soft);
    background: var(--color-surface);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    transition: box-shadow 320ms ease, transform 320ms ease;
  }

  .suggest-aside:hover {
    box-shadow: var(--shadow-glow);
  }

  @media (prefers-reduced-motion: no-preference) {
    .suggest-aside:hover {
      transform: translateY(-2px);
    }
  }

  .suggest-eyebrow {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-teal);
  }

  .suggest-heading {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 400;
    color: var(--color-text-strong);
    line-height: 1.2;
  }

  .suggest-body {
    margin: 0;
    max-width: 56ch;
    color: var(--color-text-muted);
    line-height: 1.75;
    font-size: 0.95rem;
  }

  .suggest-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    margin-top: var(--space-2);
    color: var(--color-accent);
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    border-bottom: 1px solid var(--color-accent-soft);
    padding-bottom: 0.1em;
    transition: border-color 180ms ease, opacity 180ms ease;
  }

  .suggest-link:hover {
    border-color: var(--color-accent);
    opacity: 0.8;
  }

  :root[data-theme='dark'] .suggest-link {
    color: var(--color-teal);
    border-bottom-color: color-mix(in oklab, var(--color-teal) 35%, transparent);
  }

  :root[data-theme='dark'] .suggest-link:hover {
    border-color: var(--color-teal);
  }

  .support-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }

  .cat-outer {
    display: flex;
    justify-content: center;
  }

  .cat-glow {
    display: inline-flex;
    margin-top: 5px;
  }

  :root[data-theme='dark'] .cat-glow {
    background: radial-gradient(circle,rgba(255, 255, 255, 0.758) 48%, transparent 62%);
  }
</style>
