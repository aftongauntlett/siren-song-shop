---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ButtonLink from '../components/ButtonLink.astro';
---

<BaseLayout title="About | Siren Song Shop" description="The story behind Siren Song Shop — a trust-first recommendation platform for things genuinely worth sharing.">
  <SiteNav />
  <main id="main-content" class="container">
    <section class="page-hero" aria-labelledby="about-heading">
      <p class="kicker">Our Story</p>
      <h1 id="about-heading">A recommendation platform built on trust.</h1>
      <p class="intro">
        Siren Song is a curated space for artists, makers, independent shops, tea, books, spirits,
        and gifting resources — every pick personally vetted and editorially accountable.
      </p>
    </section>

    <section aria-labelledby="mission-heading" class="content-section">
      <h2 id="mission-heading" class="section-heading" data-reveal>What we believe</h2>
      <p class="section-copy" data-reveal data-reveal-delay="1">
        Great recommendations have a human voice behind them. We don't publish anything we
        wouldn't confidently give to a close friend. No affiliate pressure, no sponsored
        placements, no algorithmic ranking — just honest taste and genuine care.
      </p>
    </section>

    <section aria-labelledby="process-heading" class="content-section">
      <h2 id="process-heading" class="section-heading" data-reveal>How picks make the list</h2>
      <p class="section-copy" data-reveal data-reveal-delay="1">
        We look for things with a real story behind them — independent makers, considered craft,
        and products that hold up over time. Every recommendation includes the rationale so you
        can decide if it fits your world, not just ours.
      </p>
    </section>

    <section aria-labelledby="support-heading" class="content-section support-section" data-reveal>
      <h2 id="support-heading" class="section-heading">Keep the lights on</h2>
      <p class="section-copy">
        Siren Song is free to use and ad-free. If it's been useful to you, a small contribution
        goes a long way!
      </p>
      <div class="support-links">
        <ButtonLink href="https://ko-fi.com/prettyprettyprettygood" target="_blank" rel="noopener noreferrer">Ko-fi</ButtonLink>
        <ButtonLink href="https://paypal.me/aftons" target="_blank" rel="noopener noreferrer" variant="ghost">PayPal</ButtonLink>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .page-hero {
    padding: var(--space-12) 0 var(--space-8);
  }

  .kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent-teal);
    font-weight: 600;
    font-size: 0.8rem;
  }

  h1 {
    margin: var(--space-2) 0 var(--space-4);
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 1.15;
    color: var(--color-text-strong);
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .intro {
    margin: 0;
    color: var(--color-text-muted);
    max-width: 56ch;
  }

  .content-section {
    padding: var(--space-8) 0;
    border-top: 1px solid var(--color-border);
  }

  .content-section .section-heading {
    margin-bottom: var(--space-4);
    transition: color 220ms ease;
  }

  .content-section:hover .section-heading {
    color: var(--color-accent-teal);
  }

  .support-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: var(--space-3);
    margin-top: var(--space-4);
    margin-bottom: calc(-1 * var(--space-2));
  }
</style>
