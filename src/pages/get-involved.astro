---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ResourceCard from '../components/ResourceCard.astro';
import TabTour from '../components/TabTour.astro';

const allResources = await getCollection('resources');

type ResourceTabId = 'work-good' | 'community-living' | 'volunteer-donate' | 'sliding-scale-support';

const categories: { id: ResourceTabId; label: string; description: string }[] = [
  {
    id: 'work-good',
    label: 'Find Good Work',
    description: 'Mission-aligned places hiring for work that feels useful and values-led.'
  },
  {
    id: 'community-living',
    label: 'Find A Community',
    description: 'Cohousing and intentional-community pathways for shared life and practical mutual support.'
  },
  {
    id: 'volunteer-donate',
    label: 'Volunteer Or Donate',
    description: 'Organizations and causes where your time or money can do direct, practical good.'
  },
  {
    id: 'sliding-scale-support',
    label: 'Sliding Scale & Free Support',
    description: 'Known, easy-to-use support resources including free lines, sliding-scale care options, and community-first LGBTQIA+ affirming help.'
  }
];

const sortFeatured = <T extends { data: { featured: boolean } }>(items: T[]) =>
  items.sort((a, b) => Number(b.data.featured) - Number(a.data.featured));

const byCategory = (id: ResourceTabId) => {
  if (id === 'work-good') {
    return sortFeatured(allResources.filter((r) => r.data.category === 'hiring'));
  }

  if (id === 'community-living') {
    return sortFeatured(allResources.filter((r) => r.data.category === 'communities'));
  }

  if (id === 'sliding-scale-support') {
    return sortFeatured(allResources.filter((r) => r.data.category === 'support'));
  }

  return sortFeatured(
    allResources.filter((r) => r.data.category === 'orgs' || r.data.category === 'charities')
  );
};
---

<BaseLayout
  title="Get Involved | Siren Song"
  description="Find work worth doing, community living options, practical ways to volunteer or donate, and sliding-scale/free support resources."
>
  <SiteNav />
  <main id="main-content" class="container">
    <section class="page-hero" aria-labelledby="resources-heading">
      <p class="kicker">Get Involved</p>
      <h1 id="resources-heading">Places Worth Your Attention</h1>
      <p class="intro">
        Not just places to browse, but places to participate. Use these tabs to find work, homes,
        and causes that align with mutual-care values.
      </p>
    </section>

    <nav class="category-nav" aria-label="Browse involvement categories">
      <div class="category-dropdown" data-category-dropdown>
        <button
          type="button"
          class="category-trigger"
          data-category-trigger
          aria-haspopup="listbox"
          aria-expanded="false"
          aria-label="Select involvement category"
        >
          <span data-category-value>{categories[0]?.label ?? ''}</span>
          <svg class="category-trigger-chevron" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
        <ul class="category-options" data-category-options aria-label="Get involved categories" hidden>
          {categories.map(({ id, label }, index) => (
            <li>
              <button
                type="button"
                class:list={['category-option', { 'category-option--active': index === 0 }]}
                data-category-option
                data-value={id}
              >
                {label}
              </button>
            </li>
          ))}
        </ul>
      </div>
      <div class="category-list" role="tablist" aria-label="Get involved categories">
        {categories.map(({ id, label }, index) => (
          <div class="category-item">
            <button
              type="button"
              class:list={['category-tab', { 'category-tab--active': index === 0 }]}
              role="tab"
              aria-selected={index === 0 ? 'true' : 'false'}
              tabindex={index === 0 ? '0' : '-1'}
              aria-controls={`${id}-panel`}
              id={`${id}-tab`}
              data-category-tab
              data-category={id}
            >
              {label}
            </button>
          </div>
        ))}
      </div>
      <TabTour />
    </nav>

    {categories.map(({ id, label, description }, index) => {
      const entries = byCategory(id);
      return (
        <section
          id={`${id}-panel`}
          aria-labelledby={`${id}-tab`}
          role="tabpanel"
          class="category-section"
          data-reveal
          data-category-panel
          data-category={id}
          hidden={index !== 0}
        >
          <header class="category-header">
            <h2 class="section-heading">{label}</h2>
            <p class="category-description">{description}</p>
          </header>
          {entries.length > 0 ? (
            <ul class="resource-grid">
              {entries.map((resource) => (
                <li>
                  <ResourceCard
                    name={resource.data.name}
                    url={resource.data.url}
                    description={resource.data.description}
                    featured={resource.data.featured}
                  />
                </li>
              ))}
            </ul>
          ) : (
            <p class="empty-state">More coming soon — added with intention.</p>
          )}
        </section>
      );
    })}
  </main>
  <SiteFooter />
</BaseLayout>

<script>
  const w = window as Window & { __sirenResourcesTabsHookBound?: boolean };

  const initializeResourceTabs = () => {
    const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-category-tab]'));
    const panels = Array.from(document.querySelectorAll<HTMLElement>('[data-category-panel]'));
    const categoryDropdown = document.querySelector<HTMLElement>('[data-category-dropdown]');
    const categoryTrigger = document.querySelector<HTMLButtonElement>('[data-category-trigger]');
    const categoryValueEl = document.querySelector<HTMLElement>('[data-category-value]');
    const categoryOptionsPanel = document.querySelector<HTMLElement>('[data-category-options]');
    const categoryOptionBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-category-option]'));
    if (tabs.length === 0 || panels.length === 0) return;

    const getTabCategory = (tab: HTMLButtonElement) => tab.dataset.category;

    const setActiveCategory = (category: string) => {
      tabs.forEach((tab) => {
        const isActive = tab.dataset.category === category;
        tab.setAttribute('aria-selected', String(isActive));
        tab.classList.toggle('category-tab--active', isActive);
        tab.tabIndex = isActive ? 0 : -1;
      });

      panels.forEach((panel) => {
        panel.hidden = panel.dataset.category !== category;
      });

      if (categoryValueEl) {
        const activeOpt = categoryOptionBtns.find((opt) => opt.dataset.value === category);
        if (activeOpt) categoryValueEl.textContent = activeOpt.textContent?.trim() ?? category;
      }
      categoryOptionBtns.forEach((opt) => {
        opt.classList.toggle('category-option--active', opt.dataset.value === category);
      });
    };

    const setActiveByIndex = (index: number) => {
      const safeIndex = (index + tabs.length) % tabs.length;
      const nextTab = tabs[safeIndex];
      if (!nextTab) return;
      const category = getTabCategory(nextTab);
      if (!category) return;
      setActiveCategory(category);
      nextTab.focus();
    };

    tabs.forEach((tab) => {
      if (tab.dataset.categoryBound === 'true') return;

      tab.addEventListener('click', () => {
        const category = getTabCategory(tab);
        if (!category) return;
        setActiveCategory(category);
      });

      tab.addEventListener('keydown', (event) => {
        const currentIndex = tabs.indexOf(tab);
        if (currentIndex < 0) return;

        if (event.key === 'ArrowRight') {
          event.preventDefault();
          setActiveByIndex(currentIndex + 1);
        }

        if (event.key === 'ArrowLeft') {
          event.preventDefault();
          setActiveByIndex(currentIndex - 1);
        }

        if (event.key === 'Home') {
          event.preventDefault();
          setActiveByIndex(0);
        }

        if (event.key === 'End') {
          event.preventDefault();
          setActiveByIndex(tabs.length - 1);
        }

        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          const category = getTabCategory(tab);
          if (!category) return;
          setActiveCategory(category);
        }
      });

      tab.dataset.categoryBound = 'true';
    });

    const closeCategoryOptions = () => {
      if (!categoryTrigger || !categoryOptionsPanel) return;
      categoryOptionsPanel.hidden = true;
      categoryTrigger.setAttribute('aria-expanded', 'false');
      if (categoryDropdown) delete categoryDropdown.dataset.open;
    };

    const openCategoryOptions = () => {
      if (!categoryTrigger || !categoryOptionsPanel) return;
      categoryOptionsPanel.hidden = false;
      categoryTrigger.setAttribute('aria-expanded', 'true');
      if (categoryDropdown) categoryDropdown.dataset.open = 'true';
    };

    if (categoryTrigger && categoryOptionsPanel && categoryTrigger.dataset.categoryTriggerBound !== 'true') {
      categoryTrigger.addEventListener('click', () => {
        if (categoryOptionsPanel.hidden) openCategoryOptions();
        else closeCategoryOptions();
      });
      categoryTrigger.addEventListener('keydown', (event) => {
        if (event.key === 'ArrowDown' || event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          openCategoryOptions();
        }
        if (event.key === 'Escape') {
          event.preventDefault();
          closeCategoryOptions();
        }
      });
      categoryTrigger.dataset.categoryTriggerBound = 'true';
    }

    categoryOptionBtns.forEach((opt) => {
      if (opt.dataset.categoryOptionBound === 'true') return;
      opt.addEventListener('click', () => {
        const value = opt.dataset.value;
        if (!value) return;
        setActiveCategory(value);
        closeCategoryOptions();
      });
      opt.dataset.categoryOptionBound = 'true';
    });

    if (categoryDropdown && categoryDropdown.dataset.categoryOutsideBound !== 'true') {
      document.addEventListener('click', (event) => {
        const target = event.target as Node;
        if (!categoryDropdown.contains(target)) closeCategoryOptions();
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') closeCategoryOptions();
      });
      categoryDropdown.dataset.categoryOutsideBound = 'true';
    }

    const firstTab = tabs.at(0);
    if (firstTab?.dataset.category) {
      setActiveCategory(firstTab.dataset.category);
    }
  };

  initializeResourceTabs();

  if (!w.__sirenResourcesTabsHookBound) {
    document.addEventListener('astro:page-load', initializeResourceTabs);
    w.__sirenResourcesTabsHookBound = true;
  }
</script>

<style>
  .page-hero {
    padding: var(--space-12) 0 var(--space-8);
  }

  .kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent-pop);
    font-weight: 600;
    font-size: 0.8rem;
  }

  h1 {
    margin: var(--space-2) 0 var(--space-4);
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 1.15;
    color: var(--color-text-strong);
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .intro {
    margin: 0;
    color: var(--color-text-muted);
  }

  .category-nav {
    margin: var(--space-8) 0 var(--space-4);
  }

  .category-dropdown {
    position: relative;
    display: inline-flex;
    flex-direction: column;
    width: 100%;
    margin-bottom: var(--space-3);
  }

  .category-trigger {
    width: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-md);
    background: color-mix(in oklab, var(--color-surface) 86%, transparent);
    color: var(--color-text-strong);
    padding: 0.5rem 0.85rem;
    font: inherit;
    font-weight: 600;
    line-height: 1.2;
    cursor: pointer;
    box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--color-accent-soft) 24%, transparent);
    transition: border-color 180ms ease, box-shadow 180ms ease, background-color 180ms ease;
  }

  .category-trigger:hover {
    border-color: color-mix(in oklab, var(--color-accent-soft) 64%, var(--color-border-soft));
    background: color-mix(in oklab, var(--color-surface) 92%, transparent);
  }

  .category-trigger:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
  }

  .category-trigger-chevron {
    color: var(--color-text-muted);
    flex-shrink: 0;
    transition: transform 180ms ease;
  }

  .category-dropdown[data-open='true'] .category-trigger-chevron {
    transform: rotate(180deg);
  }

  .category-options {
    display: none;
    list-style: none;
    position: absolute;
    top: calc(100% + 0.35rem);
    left: 0;
    right: 0;
    z-index: 10;
    margin: 0;
    padding: 0.35rem;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: var(--radius-md);
    background: var(--color-surface-card);
    box-shadow: 0 14px 28px -12px rgba(0, 0, 0, 0.35);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  :root[data-theme='dark'] .category-options {
    border-color: var(--color-border-soft);
    background: color-mix(in srgb, var(--color-bg) 94%, transparent);
    box-shadow: 0 14px 28px -24px rgba(0, 0, 0, 0.42);
  }

  .category-dropdown[data-open='true'] .category-options {
    display: block;
  }

  .category-option {
    width: 100%;
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    padding: 0.45rem 0.6rem;
    background: transparent;
    color: rgba(255, 255, 255, 0.75);
    text-align: left;
    font: inherit;
    font-weight: 600;
    cursor: pointer;
    transition: color 180ms ease, background-color 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  :root[data-theme='dark'] .category-option {
    color: var(--color-text-muted);
  }

  .category-option:hover,
  .category-option:focus-visible {
    color: var(--color-on-accent);
    background: rgba(255, 255, 255, 0.14);
    outline: none;
  }

  :root[data-theme='dark'] .category-option:hover,
  :root[data-theme='dark'] .category-option:focus-visible {
    color: var(--color-text-strong);
    background: var(--color-surface-strong);
  }

  .category-option--active {
    color: var(--color-on-accent);
    background: rgba(255, 255, 255, 0.2);
    border-color: rgba(255, 255, 255, 0.3);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.12);
  }

  :root[data-theme='dark'] .category-option--active {
    color: var(--color-text-strong);
    background: var(--color-surface-strong);
    border-color: color-mix(in oklab, var(--color-accent-soft) 70%, var(--color-border-soft));
    box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--color-accent) 25%, transparent);
  }

  .category-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: nowrap;
    gap: 0;
    overflow-x: auto;
    border-bottom: 1px solid var(--color-border-soft);
  }

  :root:not([data-theme='dark']) .category-list {
    border-bottom-color: color-mix(in oklab, var(--color-accent-strong) 28%, var(--color-border-soft) 72%);
  }

  .category-item {
    flex: 0 0 auto;
  }

  .category-tab {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-4);
    border: 0;
    border-bottom: 2px solid transparent;
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    font: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    white-space: nowrap;
    transition: background-color 200ms ease, border-color 200ms ease, color 200ms ease, box-shadow 200ms ease;
  }

  .category-tab:hover {
    background: var(--color-surface-strong);
    color: var(--color-text-strong);
  }

  :root:not([data-theme='dark']) .category-tab:hover {
    background: color-mix(in oklab, var(--color-surface) 66%, var(--color-bg) 34%);
  }

  .category-tab--active,
  .category-tab[aria-selected='true'] {
    background: color-mix(in oklab, var(--color-surface-strong) 86%, transparent);
    border-bottom-color: var(--color-tab-underline);
    color: var(--color-text-strong);
  }

  :root:not([data-theme='dark']) .category-tab--active,
  :root:not([data-theme='dark']) .category-tab[aria-selected='true'] {
    background: var(--color-surface-card);
    border-bottom-color: var(--color-tab-underline);
    color: var(--color-on-accent);
    box-shadow: none;
  }

  .category-tab:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
    border-radius: var(--radius-sm);
  }

  .category-section {
    padding: var(--space-6) 0;
  }

  .category-header {
    margin-bottom: var(--space-6);
  }

  .category-header .section-heading {
    margin-bottom: var(--space-2);
  }

  .category-description {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.95rem;
    max-width: none;
  }

  .resource-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-4);
  }

  .resource-grid > li {
    display: flex;
  }

  .empty-state {
    font-style: italic;
    opacity: 0.7;
    margin: 0;
  }

  @media (min-width: 48rem) {
    .category-dropdown {
      display: none;
    }

    .category-list {
      overflow-x: visible;
    }

    .category-item {
      flex: 1 1 auto;
    }

    .category-tab {
      width: 100%;
    }

    .resource-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 47.99rem) {
    .category-list {
      display: none;
    }
  }

  @media (min-width: 64rem) {
    .resource-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
