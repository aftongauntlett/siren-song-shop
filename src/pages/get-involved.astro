---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ResourceCard from '../components/ResourceCard.astro';
import CategoryTabsNav from '../components/CategoryTabsNav.astro';

const allResources = await getCollection('resources');

type ResourceTabId = 'work-good' | 'community-living' | 'volunteer-donate' | 'sliding-scale-support';

const categories: { id: ResourceTabId; label: string; description: string }[] = [
  {
    id: 'work-good',
    label: 'Find Good Work',
    description: 'Places hiring for work that actually feels worth doing.'
  },
  {
    id: 'community-living',
    label: 'Find A Community',
    description: 'Cohousing and intentional communities for people who want to live a little less alone.'
  },
  {
    id: 'volunteer-donate',
    label: 'Volunteer Or Donate',
    description: 'Organizations and causes where your time or money can do direct, practical good.'
  },
  {
    id: 'sliding-scale-support',
    label: 'Sliding Scale & Free Support',
    description: 'Known, easy-to-access support including free lines, sliding-scale care, and LGBTQIA+ affirming help.'
  }
];

const sortFeatured = <T extends { data: { featured: boolean } }>(items: T[]) =>
  items.sort((a, b) => Number(b.data.featured) - Number(a.data.featured));

const byCategory = (id: ResourceTabId) => {
  if (id === 'work-good') {
    return sortFeatured(allResources.filter((r) => r.data.category === 'hiring'));
  }

  if (id === 'community-living') {
    return sortFeatured(allResources.filter((r) => r.data.category === 'communities'));
  }

  if (id === 'sliding-scale-support') {
    return sortFeatured(allResources.filter((r) => r.data.category === 'support'));
  }

  return sortFeatured(
    allResources.filter((r) => r.data.category === 'orgs' || r.data.category === 'charities')
  );
};
---

<BaseLayout
  title="Get Involved | Siren Song"
  description="Find work worth doing, community living options, practical ways to volunteer or donate, and sliding-scale/free support resources."
>
  <SiteNav />
  <main id="main-content" class="container">
    <section class="page-hero" aria-labelledby="resources-heading">
      <p class="kicker">Get Involved</p>
      <h1 id="resources-heading">Places Worth Your Attention</h1>
      <p class="intro">
        Places to plug into, not just bookmark. Work, community, causes, and support resources worth knowing about.
      </p>
    </section>

    <CategoryTabsNav
      categories={categories.map(({ id, label }) => ({ id, label }))}
      ariaLabel="Get involved categories"
      dropdownLabel="Select involvement category"
    />

    {categories.map(({ id, label, description }, index) => {
      const entries = byCategory(id);
      return (
        <section
          id={`${id}-panel`}
          aria-labelledby={`${id}-tab`}
          role="tabpanel"
          class="category-section"
          data-reveal
          data-category-panel
          data-category={id}
          hidden={index !== 0}
        >
          <header class="category-header">
            <h2 class="section-heading">{label}</h2>
            <p class="category-description">{description}</p>
          </header>
          {entries.length > 0 ? (
            <ul class="resource-grid">
              {entries.map((resource) => (
                <li>
                  <ResourceCard
                    name={resource.data.name}
                    url={resource.data.url}
                    description={resource.data.description}
                    featured={resource.data.featured}
                  />
                </li>
              ))}
            </ul>
          ) : (
            <p class="empty-state">More coming soon — added with intention.</p>
          )}
        </section>
      );
    })}
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .page-hero {
    padding: var(--space-12) 0 var(--space-8);
  }

  .kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent-pop);
    font-weight: 600;
    font-size: 0.8rem;
  }

  h1 {
    margin: var(--space-2) 0 var(--space-4);
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 1.15;
    color: var(--color-text-strong);
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .intro {
    margin: 0;
    color: var(--color-text-muted);
  }

  .category-section {
    padding: var(--space-6) 0;
  }

  .category-header {
    margin-bottom: var(--space-6);
  }

  .category-header .section-heading {
    margin-bottom: var(--space-2);
  }

  .category-description {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.95rem;
    max-width: none;
  }

  .resource-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-4);
  }

  .resource-grid > li {
    display: flex;
  }

  .empty-state {
    font-style: italic;
    opacity: 0.7;
    margin: 0;
  }

  @media (min-width: 48rem) {
    .resource-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 64rem) {
    .resource-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
