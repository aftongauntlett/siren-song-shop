---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout title="Contact | Siren Song Shop" description="Suggest a find or get in touch with the Siren Song Shop team.">
  <SiteNav />
  <main id="main-content" class="container">
    <section class="page-hero" aria-labelledby="contact-heading">
      <p class="kicker">Get in Touch</p>
      <h1 id="contact-heading">Suggest a find or say hello.</h1>
      <p class="intro">
        Know a hidden gem that deserves a spot? Send a note and we'll review it personally —
        every submission is read with care.
      </p>
    </section>

    <div class="form-wrapper">
      <ContactForm />
    </div>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .page-hero {
    padding: var(--space-12) 0 var(--space-8);
    max-width: 64ch;
  }

  .kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent-teal);
    font-weight: 600;
    font-size: 0.8rem;
  }

  h1 {
    margin: var(--space-2) 0 var(--space-4);
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 1.15;
    color: var(--color-text-strong);
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .intro {
    margin: 0;
    color: var(--color-text-muted);
    max-width: 56ch;
  }

  .form-wrapper {
    padding-bottom: var(--space-16);
    max-width: 40rem;
  }
</style>
