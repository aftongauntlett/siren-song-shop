---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ContactForm from '../components/ContactForm.astro';
import ButtonLink from '../components/ButtonLink.astro';
import mermaidImg from '../assets/mermaid.jpg';
---

<BaseLayout title="Contact | Siren Song Shop" description="Suggest a find or get in touch with the Siren Song Shop team.">
  <SiteNav />
  <main id="main-content" class="container">
    <section class="page-hero" aria-labelledby="contact-heading">
      <p class="kicker">Get in Touch</p>
      <h1 id="contact-heading">Suggest a find or say hello.</h1>
      <p class="intro">
        Know something that belongs here? Send us a note and we'll take a look. Every message gets a real read.
      </p>
    </section>

    <div class="contact-layout">
      <div class="contact-image-wrap">
        <Image
          src={mermaidImg}
          alt="A watercolour mermaid illustration"
          width={700}
          height={900}
          class="contact-image"
        />
      </div>
      <ContactForm />
    </div>

    <aside class="discord-aside" aria-labelledby="discord-heading">
      <p class="discord-eyebrow">Community</p>
      <h2 id="discord-heading" class="discord-heading">We have a Discord.</h2>
      <p class="discord-body">It's small on purpose. Come hang out, suggest finds, or just say hello.</p>
      <ButtonLink href="https://discord.gg/7t8R99ng" target="_blank" rel="noopener noreferrer">
        Join the Discord
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M6 3h7v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M10 6L3 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </ButtonLink>
    </aside>

    <aside class="pppg-aside" aria-labelledby="pppg-heading">
      <p class="pppg-eyebrow">While you're here</p>
      <h2 id="pppg-heading" class="pppg-heading">Want a site like this one?</h2>
      <p class="pppg-body">We build thoughtful websites for artists, makers, and organisations doing good work — on sliding-scale fees, because good design shouldn't cost what most small orgs can afford. If that's you, we'd love to talk.</p>
      <a class="pppg-link" href="https://prettyprettyprettygood.org" target="_blank" rel="noopener noreferrer" aria-label="Visit Pretty Pretty Pretty Good (opens in new tab)">
        Learn more at Pretty Pretty Pretty Good
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M6 3h7v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M10 6L3 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </aside>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .page-hero {
    padding: var(--space-12) 0 var(--space-8);
  }

  .kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent-pop);
    font-weight: 600;
    font-size: 0.8rem;
  }

  h1 {
    margin: var(--space-2) 0 var(--space-4);
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 1.15;
    color: var(--color-text-strong);
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .intro {
    margin: 0;
    color: var(--color-text-muted);
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: stretch;
    padding-bottom: var(--space-16);
  }

  .contact-image-wrap {
    border-radius: 1.5rem;
    overflow: hidden;
    box-shadow: var(--shadow-image-glow);
  }

  :root:not([data-theme='dark']) .contact-image-wrap {
    box-shadow: 0 0 0 1px var(--color-border-soft);
  }

  .contact-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center top;
  }

  @media (max-width: 48rem) {
    .contact-layout {
      grid-template-columns: 1fr;
    }

    .contact-image-wrap {
      height: 24rem;
    }

    .contact-image {
      height: 100%;
    }
  }

  .discord-aside {
    margin: var(--space-8) 0 0;
    padding: var(--space-8);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border-soft);
    background: var(--color-surface);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .discord-eyebrow {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-accent-pop);
  }

  :root:not([data-theme='dark']) .discord-eyebrow {
    color: var(--color-accent);
  }

  .discord-heading {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 400;
    color: var(--color-text-strong);
    line-height: 1.2;
  }

  .discord-body {
    margin: 0;
    max-width: 48ch;
    color: var(--color-text-muted);
    line-height: 1.75;
    font-size: 0.95rem;
  }

  .pppg-aside {
    margin-top: var(--space-8);
    padding: var(--space-8);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border-soft);
    background: var(--color-surface);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    transition: box-shadow 320ms ease, transform 320ms ease;
  }

  .pppg-aside:hover {
    box-shadow: var(--shadow-glow);
  }

  @media (prefers-reduced-motion: no-preference) {
    .pppg-aside:hover {
      transform: translateY(-2px);
    }
  }

  .pppg-eyebrow {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-accent-pop);
  }

  :root:not([data-theme='dark']) .pppg-eyebrow {
    color: var(--color-accent);
  }

  .pppg-heading {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 400;
    color: var(--color-text-strong);
    line-height: 1.2;
  }

  .pppg-body {
    margin: 0;
    max-width: 56ch;
    color: var(--color-text-muted);
    line-height: 1.75;
    font-size: 0.95rem;
  }

  .pppg-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    margin-top: var(--space-2);
    color: var(--color-accent);
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    border-bottom: 1px solid var(--color-accent-soft);
    padding-bottom: 0.1em;
    transition: border-color 180ms ease, opacity 180ms ease;
  }

  .pppg-link:hover {
    border-color: var(--color-accent);
    opacity: 0.8;
  }

  :root[data-theme='dark'] .pppg-link {
    color: var(--color-teal);
    border-bottom-color: color-mix(in oklab, var(--color-teal) 35%, transparent);
  }

  :root[data-theme='dark'] .pppg-link:hover {
    border-color: var(--color-teal);
  }
</style>
