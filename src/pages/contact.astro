---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout title="Contact | Siren Song Shop" description="Suggest a find or get in touch with the Siren Song Shop team.">
  <SiteNav />
  <main id="main-content" class="container">
    <section class="page-hero" aria-labelledby="contact-heading">
      <p class="kicker">Get in Touch</p>
      <h1 id="contact-heading">Suggest a find or say hello.</h1>
      <p class="intro">
        Know a hidden gem that deserves a spot? Send a note and we'll review it personally —
        every submission is read with care.
      </p>
    </section>

    <div class="contact-layout">
      <div class="contact-image-wrap">
        <Image
          src="/images/mermaid.jpg"
          alt="A watercolour mermaid illustration"
          width={700}
          height={900}
          class="contact-image"
        />
      </div>
      <ContactForm />
    </div>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .page-hero {
    padding: var(--space-12) 0 var(--space-8);
  }

  .kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent-teal);
    font-weight: 600;
    font-size: 0.8rem;
  }

  h1 {
    margin: var(--space-2) 0 var(--space-4);
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 1.15;
    color: var(--color-text-strong);
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .intro {
    margin: 0;
    color: var(--color-text-muted);
    max-width: 56ch;
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: stretch;
    padding-bottom: var(--space-16);
  }

  .contact-image-wrap {
    border-radius: 1.5rem;
    overflow: hidden;
    box-shadow:
      0 0 0 1px var(--color-border-soft),
      0 8px 32px rgba(109, 40, 217, 0.22),
      0 0 80px rgba(109, 40, 217, 0.16),
      0 0 120px rgba(13, 148, 136, 0.12);
  }

  .contact-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center top;
  }

  @media (max-width: 48rem) {
    .contact-layout {
      grid-template-columns: 1fr;
    }

    .contact-image-wrap {
      height: 24rem;
    }

    .contact-image {
      height: 100%;
    }
  }
</style>
