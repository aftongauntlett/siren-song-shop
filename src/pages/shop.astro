---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ResourceCard from '../components/ResourceCard.astro';
import { getRecommendations } from '../lib/recommendations';
import type { RecommendationCategory } from '../lib/schemas/recommendation';

const recommendations = getRecommendations();

const categoryMeta: Record<RecommendationCategory, { label: string; description: string }> = {
  'arts-crafts': {
    label: 'Arts & Crafts',
    description: 'Studios, tools, and handmade goods that keep creative practice tactile and joyful.'
  },
  'food-drinks': {
    label: 'Food & Drinks',
    description: 'Pantry staples, coffee, and beverage picks that feel grounded and worth the reorder.'
  },
  'bath-body': {
    label: 'Bath & Body',
    description: 'Body care and fragrance with personality, quality ingredients, and daily-use comfort.'
  },
  'media': {
    label: 'Media',
    description: 'Independent books and media sources for learning, delight, and useful perspective shifts.'
  },
  clothing: {
    label: 'Clothing',
    description: 'Wearable basics and apparel brands with stronger ethics and better long-term value.'
  }
};

const categories: RecommendationCategory[] = ['arts-crafts', 'food-drinks', 'bath-body', 'media', 'clothing'];

const byCategory = (category: RecommendationCategory) =>
  recommendations.filter((item) => item.category === category);
---

<BaseLayout title="Browse Shops | Siren Song Shop" description="Shop by category across arts and crafts, pantry favorites, body care, media, and clothing picks. Personally vetted, no filler.">
  <SiteNav />
  <main id="main-content" class="container">
    <section class="page-hero" aria-labelledby="rec-heading">
      <p class="kicker">Browse Shops</p>
      <h1 id="rec-heading">Shops worth bookmarking.</h1>
      <p class="intro">
        These are the shops we keep coming back to. Filter by category to stay in one lane and find what you need faster.
      </p>
    </section>

    <nav class="category-nav" aria-label="Browse shop categories">
      <div class="category-select-wrap">
        <label class="visually-hidden" for="recommendations-category-select">Shop category</label>
        <select id="recommendations-category-select" class="category-select" data-category-select>
          {categories.map((category) => (
            <option value={category}>{categoryMeta[category].label}</option>
          ))}
        </select>
      </div>
      <div class="category-list" role="tablist" aria-label="Shop categories">
        {categories.map((category, index) => (
          <div class="category-item">
            <button
              type="button"
              class:list={['category-tab', { 'category-tab--active': index === 0 }]}
              role="tab"
              aria-selected={index === 0 ? 'true' : 'false'}
              tabindex={index === 0 ? '0' : '-1'}
              aria-controls={`${category}-panel`}
              id={`${category}-tab`}
              data-category-tab
              data-category={category}
            >
              {categoryMeta[category].label}
            </button>
          </div>
        ))}
      </div>
    </nav>

    {categories.map((category, index) => {
      const entries = byCategory(category);
      return (
        <section
          id={`${category}-panel`}
          aria-labelledby={`${category}-tab`}
          role="tabpanel"
          class="category-section"
          data-reveal
          data-category-panel
          data-category={category}
          hidden={index !== 0}
        >
          <header class="category-header">
            <h2 class="section-heading">{categoryMeta[category].label}</h2>
            <p class="section-copy">{categoryMeta[category].description}</p>
          </header>
          {entries.length > 0 ? (
            <ul class="recommendation-grid">
              {entries.map((item) => (
                <li>
                  <ResourceCard
                    name={item.title}
                    url={item.url}
                    description={item.excerpt}
                  />
                </li>
              ))}
            </ul>
          ) : (
            <p class="section-copy empty-state">Recommendations coming soon — handpicked with care.</p>
          )}
        </section>
      );
    })}
  </main>
  <SiteFooter />
</BaseLayout>

<script>
  const w = window as Window & { __sirenRecommendationsTabsHookBound?: boolean };

  const initializeRecommendationTabs = () => {
    const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-category-tab]'));
    const panels = Array.from(document.querySelectorAll<HTMLElement>('[data-category-panel]'));
    const categorySelect = document.querySelector<HTMLSelectElement>('[data-category-select]');
    if (tabs.length === 0 || panels.length === 0) return;

    const getTabCategory = (tab: HTMLButtonElement) => tab.dataset.category;

    const setActiveCategory = (category: string) => {
      tabs.forEach((tab) => {
        const isActive = tab.dataset.category === category;
        tab.setAttribute('aria-selected', String(isActive));
        tab.classList.toggle('category-tab--active', isActive);
        tab.tabIndex = isActive ? 0 : -1;
      });

      panels.forEach((panel) => {
        panel.hidden = panel.dataset.category !== category;
      });

      if (categorySelect && categorySelect.value !== category) {
        categorySelect.value = category;
      }
    };

    const setActiveByIndex = (index: number) => {
      const safeIndex = (index + tabs.length) % tabs.length;
      const nextTab = tabs[safeIndex];
      if (!nextTab) return;
      const category = getTabCategory(nextTab);
      if (!category) return;
      setActiveCategory(category);
      nextTab.focus();
    };

    tabs.forEach((tab) => {
      if (tab.dataset.categoryBound === 'true') return;

      tab.addEventListener('click', () => {
        const category = getTabCategory(tab);
        if (!category) return;
        setActiveCategory(category);
      });

      tab.addEventListener('keydown', (event) => {
        const currentIndex = tabs.indexOf(tab);
        if (currentIndex < 0) return;

        if (event.key === 'ArrowRight') {
          event.preventDefault();
          setActiveByIndex(currentIndex + 1);
        }

        if (event.key === 'ArrowLeft') {
          event.preventDefault();
          setActiveByIndex(currentIndex - 1);
        }

        if (event.key === 'Home') {
          event.preventDefault();
          setActiveByIndex(0);
        }

        if (event.key === 'End') {
          event.preventDefault();
          setActiveByIndex(tabs.length - 1);
        }

        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          const category = getTabCategory(tab);
          if (!category) return;
          setActiveCategory(category);
        }
      });

      tab.dataset.categoryBound = 'true';
    });

    if (categorySelect && categorySelect.dataset.categorySelectBound !== 'true') {
      categorySelect.addEventListener('change', () => {
        setActiveCategory(categorySelect.value);
      });
      categorySelect.dataset.categorySelectBound = 'true';
    }

    const firstTab = tabs.at(0);
    if (firstTab?.dataset.category) {
      setActiveCategory(firstTab.dataset.category);
    }
  };

  initializeRecommendationTabs();

  if (!w.__sirenRecommendationsTabsHookBound) {
    document.addEventListener('astro:page-load', initializeRecommendationTabs);
    w.__sirenRecommendationsTabsHookBound = true;
  }
</script>

<style>
  .page-hero {
    padding: var(--space-12) 0 var(--space-8);
  }

  .kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent-teal);
    font-weight: 600;
    font-size: 0.8rem;
  }

  h1 {
    margin: var(--space-2) 0 var(--space-4);
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 1.15;
    color: var(--color-text-strong);
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .intro {
    margin: 0;
    color: var(--color-text-muted);
    max-width: 56ch;
  }

  .category-nav {
    margin: var(--space-8) 0 var(--space-4);
  }

  .category-select-wrap {
    margin-bottom: var(--space-3);
  }

  .category-select {
    width: 100%;
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-sm);
    background: var(--color-surface-card);
    color: var(--color-text-strong);
    padding: 0.55rem 0.75rem;
    font: inherit;
  }

  .category-select:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
  }

  .category-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: nowrap;
    gap: 0;
    overflow-x: auto;
    border-bottom: 1px solid var(--color-border-soft);
  }

  :root:not([data-theme='dark']) .category-list {
    border-bottom-color: color-mix(in oklab, var(--color-accent-strong) 28%, var(--color-border-soft) 72%);
  }

  .category-item {
    flex: 0 0 auto;
  }

  .category-tab {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-4);
    border: 0;
    border-bottom: 2px solid transparent;
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    font: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    white-space: nowrap;
    transition: background-color 200ms ease, border-color 200ms ease, color 200ms ease, box-shadow 200ms ease;
  }

  .category-tab:hover {
    background: var(--color-surface-strong);
    color: var(--color-text-strong);
  }

  :root:not([data-theme='dark']) .category-tab:hover {
    background: color-mix(in oklab, var(--color-surface) 66%, var(--color-bg) 34%);
  }

  .category-tab--active,
  .category-tab[aria-selected='true'] {
    background: color-mix(in oklab, var(--color-surface-strong) 86%, transparent);
    border-bottom-color: var(--color-accent-teal);
    color: var(--color-text-strong);
  }

  :root:not([data-theme='dark']) .category-tab--active,
  :root:not([data-theme='dark']) .category-tab[aria-selected='true'] {
    background: color-mix(in oklab, var(--color-surface) 70%, var(--color-bg) 30%);
    box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--color-accent-soft) 58%, var(--color-border-soft));
  }

  .category-tab:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
    border-radius: var(--radius-sm);
  }

  @media (min-width: 48rem) {
    .category-select-wrap {
      display: none;
    }

    .category-list {
      overflow-x: visible;
    }

    .category-item {
      flex: 1 1 auto;
    }

    .category-tab {
      width: 100%;
    }
  }

  @media (max-width: 47.99rem) {
    .category-list {
      display: none;
    }
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .category-section {
    padding: var(--space-6) 0;
  }

  .category-header {
    margin-bottom: var(--space-5);
  }

  .category-section .section-heading {
    margin-bottom: var(--space-4);
  }

  .recommendation-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-4);
  }

  .recommendation-grid > li {
    display: flex;
  }

  .empty-state {
    font-style: italic;
    opacity: 0.7;
  }

  @media (min-width: 48rem) {
    .recommendation-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 64rem) {
    .recommendation-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
