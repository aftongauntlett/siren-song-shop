---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import FeatureCard from '../components/FeatureCard.astro';
import AccordionItem from '../components/AccordionItem.astro';
import HomeCurationSteps from '../components/HomeCurationSteps.astro';
import HomeShopSpotlight from '../components/HomeShopSpotlight.astro';

const previewCards = [
  {
    eyebrow: 'Shop',
    title: 'Independent Shops & Craft',
    description: 'Shops and makers we actually buy from. Focused on craft, sustainability, and the people doing the work.',

    href: '/shop',
    cta: 'Browse the Wares'
  },
  {
    eyebrow: 'Get Involved',
    title: 'Work, Community & Mutual Aid',
    description: 'Job openings, local events, and mutual aid you can actually plug into. Real ways to find your people and contribute.',

    href: '/get-involved',
    cta: 'Get Involved'
  },
  {
    eyebrow: 'Local',
    title: 'Local Picks Near You',
    description: 'Local shops, makers, and resources we\'d point a friend to. The good stuff that\'s easy to miss if you don\'t know where to look.',

    href: '/local',
    cta: 'See Local Picks'
  }
] as const;

interface AccordionEntry {
  title: string;
  body: string;
  linkHref?: string;
  linkLabel?: string;
  linkExternal?: boolean;
}

const accordionItems: AccordionEntry[] = [
  {
    title: 'Are these recommendations paid or sponsored?',
    body: 'Never. Every pick is something we genuinely use, love, or would hand to a friend without hesitation. No affiliate deals, no paid placements, no brand relationships of any kind. We have nothing to gain from recommending something except the good feeling of pointing someone toward something real.',
  },
  {
    title: 'Do you run ads or track me?',
    body: 'No ads, no trackers, no analytics scripts watching what you click. We don\'t monetize your attention and we don\'t sell or share your data. The site exists because we want it to, not because it has to pay for itself through you.',
  },
  {
    title: 'How do you choose what makes the cut?',
    body: 'We look for things with a real story: independent makers, good craft, and products that hold up over time. If we wouldn\'t recommend it to a close friend, it doesn\'t appear here. We add new picks slowly and intentionally — a shorter list we truly believe in beats a long one padded with noise.',
  },
  {
    title: 'Are your recommendations vegan-friendly?',
    body: 'Yes. We prioritize shops that support vegan products, and we call out shops that are 100% vegan. We avoid farm or pet-focused picks unless they are clearly animal-protection aligned (for example, sanctuary, rescue or rehabilitation efforts).',
  },
  {
    title: 'What\'s the "Get Involved" section?',
    body: 'It\'s for people who want to do something, not just buy something. You\'ll find ethical job listings, intentional communities and cohousing directories, ways to volunteer or donate, and sliding-scale or free support resources. It\'s the same values that drive the shop recommendations (mutual care and community first), just pointed outward.',
    linkHref: '/get-involved',
    linkLabel: 'Browse Get Involved',
  },
  {
    title: 'I know a shop that would be a great fit — can I suggest it?',
    body: "Absolutely, please do. Whether you're a maker who'd like to be considered, or you just want to pass along something you love, we'd genuinely love to hear about it. Reach out through our contact page and tell us a little about the shop.",
    linkHref: '/contact',
    linkLabel: 'Get in touch',
  },
];
---

<BaseLayout title="Siren Song | Curated Recommendations">
  <SiteNav />
  <SiteHeader />
  <div class="hero-section-divider" aria-hidden="true"></div>
  <main id="main-content" class="container">
    <section aria-labelledby="component-preview-heading" class="component-preview">
      <h2 id="component-preview-heading" class="section-heading" data-reveal>What's Here</h2>
      <p class="section-copy" data-reveal data-reveal-delay="1">Three sections, all built around the same idea - pointing you toward things and people actually worth your time.</p>
      <div class="grid">
        <div data-reveal data-reveal-delay="1" class="card-cell">
          <FeatureCard {...previewCards[0]}>
            <svg slot="icon" width="32" height="32" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <circle cx="13.5" cy="6.5" r=".5" fill="currentColor" stroke="currentColor" stroke-width="1.5" />
              <circle cx="17.5" cy="10.5" r=".5" fill="currentColor" stroke="currentColor" stroke-width="1.5" />
              <circle cx="8.5" cy="7.5" r=".5" fill="currentColor" stroke="currentColor" stroke-width="1.5" />
              <circle cx="6.5" cy="12.5" r=".5" fill="currentColor" stroke="currentColor" stroke-width="1.5" />
              <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </FeatureCard>
        </div>
        <div data-reveal data-reveal-delay="2" class="card-cell">
          <FeatureCard {...previewCards[1]}>
            <svg slot="icon" width="32" height="32" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </FeatureCard>
        </div>
        <div data-reveal data-reveal-delay="3" class="card-cell">
          <FeatureCard {...previewCards[2]}>
            <svg slot="icon" width="32" height="32" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.159.69.159 1.006 0Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </FeatureCard>
        </div>
      </div>
      <p class="section-about-link" data-reveal>
        Curious who's behind this? <a href="/about">Read our story →</a>
      </p>
    </section>

    <HomeShopSpotlight />

    <HomeCurationSteps />

    <section aria-labelledby="faq-heading" class="faq">
      <h2 id="faq-heading" class="section-heading" data-reveal>Quick FAQ</h2>
      <div class="faq-list">
        {accordionItems.map((item, i) => (
          <div data-reveal data-reveal-delay={String(i + 1) as '1' | '2' | '3' | '4'}>
            <AccordionItem
              title={item.title}
              body={item.body}
              {...(item.linkHref ? { linkHref: item.linkHref } : {})}
              {...(item.linkLabel ? { linkLabel: item.linkLabel } : {})}
              {...(item.linkExternal !== undefined ? { linkExternal: item.linkExternal } : {})}
            />
          </div>
        ))}
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .hero-section-divider {
    display: none;
  }

  :root:not([data-theme='dark']) .hero-section-divider {
    display: block;
    width: min(100% - 2rem, var(--container-max));
    margin: 0 auto;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--color-border-soft) 20%,
      var(--color-accent-soft) 50%,
      var(--color-border-soft) 80%,
      transparent 100%
    );
  }

  :root[data-theme='dark'] .hero-section-divider {
    display: block;
    width: min(100% - 2rem, var(--container-max));
    margin: 0 auto;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--color-border-soft) 20%,
      var(--color-border) 50%,
      var(--color-border-soft) 80%,
      transparent 100%
    );
  }

  main.container {
    padding-bottom: var(--space-20);
  }

  :global(main.container > section + section) {
    padding-top: clamp(var(--space-10), 6vw, 4.5rem);
    position: relative;
  }

  :global(main.container > section + section::before) {
    content: '';
    display: block;
    height: 1px;
    margin-bottom: clamp(var(--space-10), 6vw, 4.5rem);
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--color-border-soft) 20%,
      var(--color-accent-soft) 50%,
      var(--color-border-soft) 80%,
      transparent 100%
    );
  }

  :global(:root[data-theme='dark'] main.container > section + section::before) {
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--color-border-soft) 20%,
      var(--color-border) 50%,
      var(--color-border-soft) 80%,
      transparent 100%
    );
  }

  .component-preview {
    margin-top: var(--space-10);
  }

  .component-preview .section-heading,
  .component-preview .section-copy,
  .faq .section-heading,
  .process .section-heading {
    text-align: center;
  }

  @media (prefers-reduced-motion: no-preference) {
    :root[data-theme='dark'] .component-preview .section-heading,
    :root[data-theme='dark'] .faq .section-heading {
      transition: color 220ms ease;
    }

    :root[data-theme='dark'] .component-preview:hover .section-heading,
    :root[data-theme='dark'] .faq:hover .section-heading {
      color: var(--color-teal);
    }
  }

  .component-preview .section-copy {
    margin-inline: auto;
    max-width: 62ch;
  }

  .section-about-link {
    margin: var(--space-6) 0 0;
    text-align: center;
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .section-about-link a {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklab, var(--color-accent) 35%, transparent);
    padding-bottom: 0.1em;
    transition: border-color 180ms ease, opacity 180ms ease;
  }

  .section-about-link a:hover {
    border-color: var(--color-accent);
    opacity: 0.8;
  }

  :root[data-theme='dark'] .section-about-link a {
    color: var(--color-teal);
    border-bottom-color: color-mix(in oklab, var(--color-teal) 35%, transparent);
  }

  :root[data-theme='dark'] .section-about-link a:hover {
    border-color: var(--color-teal);
  }

  .grid {
    display: grid;
    gap: var(--space-4);
    margin-top: var(--space-6);
    align-items: stretch;
  }

  .card-cell {
    display: flex;
    flex-direction: column;
  }

  .faq-list {
    display: grid;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }

  @media (min-width: 48rem) {
    .grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 64rem) {
    .grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>

