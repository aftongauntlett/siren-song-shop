---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import FeatureCard from '../components/FeatureCard.astro';
import AccordionItem from '../components/AccordionItem.astro';
import HomeValuesChips from '../components/HomeValuesChips.astro';
import HomePurposePanel from '../components/HomePurposePanel.astro';
import HomeCurationSteps from '../components/HomeCurationSteps.astro';
import HomeShopSpotlight from '../components/HomeShopSpotlight.astro';

const previewCards = [
  {
    eyebrow: 'Curation',
    title: 'Personally Vouched, Every Time',
    description: 'No affiliate pressure, no sponsored slots. Every recommendation here is something the curator genuinely uses, loves, or would give to a close friend.',
    href: '/about',
    cta: 'Learn More'
  },
  {
    eyebrow: 'Makers',
    title: 'Independent Shops & Craft',
    description: 'We spotlight small producers and values-led makers who bring real craft and story to what they make — not scale for its own sake.',
    href: '/shop',
    cta: 'Browse the Wares'
  },
  {
    eyebrow: 'Local',
    title: 'Find Local Living & Work Paths',
    description: 'Use the Local tab to discover nearby housing options, values-aligned jobs, and community-rooted opportunities with like-minded people.',
    href: '/local',
    cta: 'Explore Local Finds'
  }
] as const;

interface AccordionEntry {
  title: string;
  body: string;
  linkHref?: string;
  linkLabel?: string;
  linkExternal?: boolean;
}

const accordionItems: AccordionEntry[] = [
  {
    title: 'Are these recommendations paid or sponsored?',
    body: 'Never. Every pick is something we genuinely use, love, or would confidently give as a gift. No affiliate pressure, no sponsored placements — just honest taste.'
  },
  {
    title: 'How do you choose what makes the cut?',
    body: 'We look for things with a real story behind them — independent makers, considered craft, and products that hold up over time. If we wouldn\'t recommend it to a close friend, it doesn\'t appear here.'
  },
  {
    title: 'How often is new content added?',
    body: 'Slowly and intentionally. We\'d rather have a shorter list of things we truly believe in than a long one padded with noise. New guides and picks are added when they\'ve earned their place.'
  },
  {
    title: 'Are your recommendations vegan-friendly?',
    body: 'Yes. We prioritize shops that support vegan products, and we call out shops that are 100% vegan. We avoid farm or pet-focused picks unless they are clearly animal-protection aligned (for example, sanctuary, rescue or rehabilitation efforts).'
  },
  {
    title: 'I know a shop that would be a great fit — can I suggest it?',
    body: "Absolutely, please do. Whether you're a maker who'd like to be considered, or you just want to pass along something you love, we'd genuinely love to hear about it. Reach out through our contact page and tell us a little about the shop.",
    linkHref: '/contact',
    linkLabel: 'Get in touch',
  },
];
---

<BaseLayout title="Siren Song | Curated Recommendations">
  <SiteNav />
  <SiteHeader />
  <div class="hero-section-divider" aria-hidden="true"></div>
  <main id="main-content" class="container">
    <section aria-labelledby="component-preview-heading" class="component-preview">
      <h2 id="component-preview-heading" class="section-heading" data-reveal>What We Believe In</h2>
      <p class="section-copy" data-reveal data-reveal-delay="1">Everything here is something we'd say yes to in person. No sponsorships, no paid placements — just taste.</p>
      <div class="grid">
        <div data-reveal data-reveal-delay="1" class="card-cell">
          <FeatureCard {...previewCards[0]}>
            <svg slot="icon" width="32" height="32" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </FeatureCard>
        </div>
        <div data-reveal data-reveal-delay="2" class="card-cell">
          <FeatureCard {...previewCards[1]}>
            <svg slot="icon" width="32" height="32" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <circle cx="13.5" cy="6.5" r=".5" fill="currentColor" stroke="currentColor" stroke-width="1.5" />
              <circle cx="17.5" cy="10.5" r=".5" fill="currentColor" stroke="currentColor" stroke-width="1.5" />
              <circle cx="8.5" cy="7.5" r=".5" fill="currentColor" stroke="currentColor" stroke-width="1.5" />
              <circle cx="6.5" cy="12.5" r=".5" fill="currentColor" stroke="currentColor" stroke-width="1.5" />
              <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </FeatureCard>
        </div>
        <div data-reveal data-reveal-delay="3" class="card-cell">
          <FeatureCard {...previewCards[2]}>
            <svg slot="icon" width="32" height="32" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.159.69.159 1.006 0Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </FeatureCard>
        </div>
      </div>
      <HomeValuesChips />
    </section>

    <HomePurposePanel />

    <HomeCurationSteps />

    <HomeShopSpotlight />

    <section aria-labelledby="faq-heading" class="faq">
      <h2 id="faq-heading" class="section-heading" data-reveal>Quick FAQ</h2>
      <div class="faq-list">
        {accordionItems.map((item, i) => (
          <div data-reveal data-reveal-delay={String(i + 1) as '1' | '2' | '3' | '4'}>
            <AccordionItem
              title={item.title}
              body={item.body}
              {...(item.linkHref ? { linkHref: item.linkHref } : {})}
              {...(item.linkLabel ? { linkLabel: item.linkLabel } : {})}
              {...(item.linkExternal !== undefined ? { linkExternal: item.linkExternal } : {})}
            />
          </div>
        ))}
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .hero-section-divider {
    display: none;
  }

  :root:not([data-theme='dark']) .hero-section-divider {
    display: block;
    width: min(100% - 2rem, var(--container-max));
    margin: 0 auto;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--color-border-soft) 20%,
      var(--color-accent-soft) 50%,
      var(--color-border-soft) 80%,
      transparent 100%
    );
  }

  :root[data-theme='dark'] .hero-section-divider {
    display: block;
    width: min(100% - 2rem, var(--container-max));
    margin: 0 auto;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--color-border-soft) 20%,
      var(--color-border) 50%,
      var(--color-border-soft) 80%,
      transparent 100%
    );
  }

  main.container {
    padding-bottom: var(--space-20);
  }

  :global(main.container > section + section) {
    padding-top: clamp(var(--space-10), 6vw, 4.5rem);
    position: relative;
  }

  :global(main.container > section + section::before) {
    content: '';
    display: block;
    height: 1px;
    margin-bottom: clamp(var(--space-10), 6vw, 4.5rem);
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--color-border-soft) 20%,
      var(--color-accent-soft) 50%,
      var(--color-border-soft) 80%,
      transparent 100%
    );
  }

  :global(:root[data-theme='dark'] main.container > section + section::before) {
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--color-border-soft) 20%,
      var(--color-border) 50%,
      var(--color-border-soft) 80%,
      transparent 100%
    );
  }

  .component-preview {
    margin-top: var(--space-10);
  }

  .component-preview .section-heading,
  .component-preview .section-copy,
  .faq .section-heading,
  .process .section-heading {
    text-align: center;
  }

  .component-preview .section-copy {
    margin-inline: auto;
    max-width: 62ch;
  }

  .grid {
    display: grid;
    gap: var(--space-4);
    margin-top: var(--space-6);
    align-items: stretch;
  }

  .card-cell {
    display: flex;
    flex-direction: column;
  }

  .faq-list {
    display: grid;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }

  @media (min-width: 48rem) {
    .grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 64rem) {
    .grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>

