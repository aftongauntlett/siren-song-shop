---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import FeatureCard from '../components/FeatureCard.astro';
import AccordionItem from '../components/AccordionItem.astro';

const previewCards = [
  {
    eyebrow: 'Curation',
    title: 'Personally Vouched, Every Time',
    description: 'No affiliate pressure, no sponsored slots. Every recommendation here is something the curator genuinely uses, loves, or would give to a close friend.',
    href: '/about',
    cta: 'Learn More'
  },
  {
    eyebrow: 'Makers',
    title: 'Independent Shops & Craft',
    description: 'We spotlight small producers and values-led makers who bring real craft and story to what they make — not scale for its own sake.',
    href: '/shop',
    cta: 'Browse the Wares'
  },
  {
    eyebrow: 'Local',
    title: 'Find Local Living & Work Paths',
    description: 'Use the Local tab to discover nearby housing options, values-aligned jobs, and community-rooted opportunities with like-minded people.',
    href: '/local',
    cta: 'Explore Local Finds'
  }
] as const;

interface AccordionEntry {
  title: string;
  body: string;
  linkHref?: string;
  linkLabel?: string;
  linkExternal?: boolean;
}

const accordionItems: AccordionEntry[] = [
  {
    title: 'Are these recommendations paid or sponsored?',
    body: 'Never. Every pick is something we genuinely use, love, or would confidently give as a gift. No affiliate pressure, no sponsored placements — just honest taste.'
  },
  {
    title: 'How do you choose what makes the cut?',
    body: 'We look for things with a real story behind them — independent makers, considered craft, and products that hold up over time. If we wouldn\'t recommend it to a close friend, it doesn\'t appear here.'
  },
  {
    title: 'How often is new content added?',
    body: 'Slowly and intentionally. We\'d rather have a shorter list of things we truly believe in than a long one padded with noise. New guides and picks are added when they\'ve earned their place.'
  },
  {
    title: 'Are your recommendations vegan-friendly?',
    body: 'Yes — and it matters. We do not recommend products that use animal-derived materials or are tested on animals. Every pick here reflects a commitment to cruelty-free, plant-based, and ethically sourced goods.'
  },
    {
    title: 'Can I get a website like this for my project?',
    body: 'Yes. If you are a shop, maker, or local project that needs a thoughtful site with personality, we can help.',
    linkHref: 'https://prettyprettyprettygood.org',
    linkLabel: 'Visit Pretty Pretty Pretty Good',
    linkExternal: true as const
  },
];
---

<BaseLayout title="Siren Song | Curated Recommendations">
  <SiteNav />
  <SiteHeader />
  <main id="main-content" class="container">
    <section aria-labelledby="component-preview-heading" class="component-preview">
      <h2 id="component-preview-heading" class="section-heading" data-reveal>What We Believe In</h2>
      <p class="section-copy" data-reveal data-reveal-delay="1">Everything here is something we'd say yes to in person. No algorithms, no sponsorships — just taste.</p>
      <div class="grid">
        <div data-reveal data-reveal-delay="1" class="card-cell">
          <FeatureCard {...previewCards[0]}>
            <svg slot="icon" width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 3l1.8 4.5L18 9.3l-4.2 1.8L12 16l-1.8-4.9L6 9.3l4.2-1.8L12 3z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              <path d="M19 3.5l.6 1.6 1.6.6-1.6.6-.6 1.6-.6-1.6-1.6-.6 1.6-.6.6-1.6z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </FeatureCard>
        </div>
        <div data-reveal data-reveal-delay="2" class="card-cell">
          <FeatureCard {...previewCards[1]}>
            <svg slot="icon" width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M16 19v-1.2c0-1.9-1.6-3.5-3.5-3.5h-1c-1.9 0-3.5 1.6-3.5 3.5V19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              <path d="M12 11.5a3 3 0 1 0 0-6 3 3 0 0 0 0 6z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              <path d="M18.5 18.5V18c0-1.3-.9-2.4-2.2-2.7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              <path d="M17.8 10.7a2.4 2.4 0 1 0 0-4.8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </FeatureCard>
        </div>
        <div data-reveal data-reveal-delay="3" class="card-cell">
          <FeatureCard {...previewCards[2]}>
            <svg slot="icon" width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <rect x="3.5" y="5" width="17" height="11" rx="2" stroke="currentColor" stroke-width="1.5" />
              <path d="M9 19h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
              <path d="M12 16v3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
            </svg>
          </FeatureCard>
        </div>
      </div>
    </section>

    <section aria-labelledby="faq-heading" class="faq">
      <h2 id="faq-heading" class="section-heading" data-reveal>Quick FAQ</h2>
      <div class="faq-list">
        {accordionItems.map((item, i) => (
          <div data-reveal data-reveal-delay={String(i + 1) as '1' | '2' | '3'}>
            <AccordionItem
              title={item.title}
              body={item.body}
              {...(item.linkHref ? { linkHref: item.linkHref } : {})}
              {...(item.linkLabel ? { linkLabel: item.linkLabel } : {})}
              {...(item.linkExternal !== undefined ? { linkExternal: item.linkExternal } : {})}
            />
          </div>
        ))}
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .component-preview,
  .faq {
    margin-top: var(--space-12);
  }

  .component-preview {
    margin-top: var(--space-10);
  }

  .grid {
    display: grid;
    gap: var(--space-4);
    margin-top: var(--space-6);
    align-items: stretch;
  }

  .card-cell {
    display: flex;
    flex-direction: column;
  }

  .faq-list {
    display: grid;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }

  @media (min-width: 48rem) {
    .grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 64rem) {
    .grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>

