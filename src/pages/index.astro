---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import FeatureCard from '../components/FeatureCard.astro';
import AccordionItem from '../components/AccordionItem.astro';
import { Sparkles, Users, Monitor } from 'lucide-astro';

const previewCards = [
  {
    eyebrow: 'Curation',
    title: 'Personally Vouched, Every Time',
    description: 'No affiliate pressure, no sponsored slots. Every recommendation here is something the curator genuinely uses, loves, or would give to a close friend.',
    href: '/recommendations',
    cta: 'See our Picks'
  },
  {
    eyebrow: 'Makers',
    title: 'Independent Shops & Craft',
    description: 'We spotlight small producers and values-led makers who bring real craft and story to what they make — not scale for its own sake.',
    href: '/recommendations',
    cta: 'Meet the Makers'
  },
  {
    eyebrow: 'Website?',
    title: 'Want a Site Like This?',
    description: 'Are you a shop or maker who deserves a site this thoughtful? We build sites that feel like you — head over to Pretty Pretty Pretty Good to find out more.',
    href: 'https://prettyprettyprettygood.org',
    cta: 'Visit PPPG',
    external: true as const
  }
] as const;

const accordionItems = [
  {
    title: 'Are these recommendations paid or sponsored?',
    body: 'Never. Every pick is something we genuinely use, love, or would confidently give as a gift. No affiliate pressure, no sponsored placements — just honest taste.'
  },
  {
    title: 'How do you choose what makes the cut?',
    body: 'We look for things with a real story behind them — independent makers, considered craft, and products that hold up over time. If we wouldn\'t recommend it to a close friend, it doesn\'t appear here.'
  },
  {
    title: 'How often is new content added?',
    body: 'Slowly and intentionally. We\'d rather have a shorter list of things we truly believe in than a long one padded with noise. New guides and picks are added when they\'ve earned their place.'
  },
  {
    title: 'Are your recommendations vegan-friendly?',
    body: 'Yes — and it matters. We do not recommend products that use animal-derived materials or are tested on animals. Every pick here reflects a commitment to cruelty-free, plant-based, and ethically sourced goods.'
  }
] as const;
---

<BaseLayout title="Siren Song | Curated Recommendations">
  <SiteNav />
  <SiteHeader />
  <main id="main-content" class="container">
    <section aria-labelledby="component-preview-heading" class="component-preview">
      <h2 id="component-preview-heading" class="section-heading" data-reveal>What We Believe In</h2>
      <p class="section-copy" data-reveal data-reveal-delay="1">Everything here is something we'd say yes to in person. No algorithms, no sponsorships — just taste.</p>
      <div class="grid">
        <div data-reveal data-reveal-delay="1" class="card-cell">
          <FeatureCard {...previewCards[0]}>
            <Sparkles slot="icon" size={28} />
          </FeatureCard>
        </div>
        <div data-reveal data-reveal-delay="2" class="card-cell">
          <FeatureCard {...previewCards[1]}>
            <Users slot="icon" size={28} />
          </FeatureCard>
        </div>
        <div data-reveal data-reveal-delay="3" class="card-cell">
          <FeatureCard {...previewCards[2]}>
            <Monitor slot="icon" size={28} />
          </FeatureCard>
        </div>
      </div>
    </section>

    <section aria-labelledby="faq-heading" class="faq">
      <h2 id="faq-heading" class="section-heading" data-reveal>Quick FAQ</h2>
      <div class="faq-list">
        {accordionItems.map((item, i) => (
          <div data-reveal data-reveal-delay={String(i + 1) as '1' | '2' | '3'}>
            <AccordionItem title={item.title} body={item.body} />
          </div>
        ))}
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .component-preview,
  .faq {
    margin-top: var(--space-12);
  }

  .component-preview {
    margin-top: var(--space-10);
  }

  .grid {
    display: grid;
    gap: var(--space-4);
    margin-top: var(--space-6);
    align-items: stretch;
  }

  .card-cell {
    display: flex;
    flex-direction: column;
  }

  .faq-list {
    display: grid;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }

  @media (min-width: 48rem) {
    .grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 64rem) {
    .grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>

