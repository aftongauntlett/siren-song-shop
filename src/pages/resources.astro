---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ResourceCard from '../components/ResourceCard.astro';

const allResources = await getCollection('resources');

type ResourceCategory = 'orgs' | 'hiring' | 'charities';

const categories: { id: ResourceCategory; label: string; description: string }[] = [
  {
    id: 'orgs',
    label: 'Organizations Doing Good',
    description: 'Mission-driven groups making a real difference — from advocacy to community building.'
  },
  {
    id: 'hiring',
    label: 'Places Hiring',
    description: 'Values-led organizations and shops with open roles worth applying to.'
  },
  {
    id: 'charities',
    label: 'Charities',
    description: 'Causes we trust and would encourage you to support.'
  }
];

const byCategory = (id: ResourceCategory) =>
  allResources
    .filter((r) => r.data.category === id)
    .sort((a, b) => Number(b.data.featured) - Number(a.data.featured));
---

<BaseLayout
  title="Resources | Siren Song"
  description="Organizations doing good, places hiring, and charities worth supporting — curated with the same care as every recommendation on this site."
>
  <SiteNav />
  <main id="main-content" class="container">
    <section class="page-hero" aria-labelledby="resources-heading">
      <p class="kicker">Resources</p>
      <h1 id="resources-heading">Places Worth Your Attention</h1>
      <p class="intro">
        Beyond product recommendations, these are organizations, employers, and causes that align
        with the values behind this site — vetted with the same care as everything else here.
      </p>
    </section>

    <nav class="category-nav" aria-label="Jump to category">
      <ul class="category-list">
        {categories.map(({ id, label }) => (
          <li>
            <a href={`#${id}`} class="category-chip">{label}</a>
          </li>
        ))}
      </ul>
    </nav>

    {categories.map(({ id, label, description }) => {
      const entries = byCategory(id);
      return (
        <section id={id} aria-labelledby={`${id}-heading`} class="category-section" data-reveal>
          <header class="category-header">
            <h2 id={`${id}-heading`} class="section-heading">{label}</h2>
            <p class="category-description">{description}</p>
          </header>
          {entries.length > 0 ? (
            <ul class="resource-grid">
              {entries.map((resource) => (
                <li>
                  <ResourceCard
                    name={resource.data.name}
                    url={resource.data.url}
                    description={resource.data.description}
                    featured={resource.data.featured}
                  />
                </li>
              ))}
            </ul>
          ) : (
            <p class="empty-state">More coming soon — added with intention.</p>
          )}
        </section>
      );
    })}
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .page-hero {
    padding: var(--space-12) 0 var(--space-8);
  }

  .kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent-teal);
    font-weight: 600;
    font-size: 0.8rem;
  }

  h1 {
    margin: var(--space-2) 0 var(--space-4);
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 1.15;
    color: var(--color-text-strong);
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .intro {
    margin: 0;
    color: var(--color-text-muted);
    max-width: 56ch;
  }

  .category-nav {
    margin: var(--space-6) 0 var(--space-10);
  }

  .category-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .category-chip {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    background: var(--color-surface);
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: background-color 200ms ease, border-color 200ms ease, color 200ms ease;
  }

  .category-chip:hover {
    background: var(--color-surface-strong);
    border-color: var(--color-accent-soft);
    color: var(--color-text-strong);
  }

  .category-section {
    padding: var(--space-8) 0;
    border-top: 1px solid var(--color-border-soft);
  }

  .category-header {
    margin-bottom: var(--space-6);
  }

  .category-header .section-heading {
    margin-bottom: var(--space-2);
  }

  .category-description {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.95rem;
    max-width: 60ch;
  }

  .resource-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-4);
  }

  .empty-state {
    font-style: italic;
    opacity: 0.7;
    margin: 0;
  }

  @media (min-width: 48rem) {
    .resource-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 64rem) {
    .resource-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
