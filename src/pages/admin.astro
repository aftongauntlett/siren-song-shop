---
import BaseLayout from '../layouts/BaseLayout.astro';

const errorCode = Astro.url.searchParams.get('error');
const nextPath = Astro.url.searchParams.get('next') ?? '/keystatic';
const isSafeNext = nextPath.startsWith('/') && !nextPath.startsWith('//');
const next = isSafeNext ? nextPath : '/keystatic';
---

<BaseLayout title="Siren Song | Admin Login" description="Sign in to manage Siren Song editorial content.">
  <main id="main-content" class="container admin-main">
    <section class="admin-card" aria-labelledby="admin-heading">
      <p class="eyebrow">Admin</p>
      <h1 id="admin-heading">Sign in to manage content</h1>
      <p class="copy">This area is restricted to editors. Use your admin credentials to continue.</p>

      {errorCode === 'invalid' && (
        <p class="error" role="alert">Sign in failed. Check your username and password.</p>
      )}

      <form method="post" action="/api/admin/login" class="login-form">
        <input type="hidden" name="next" value={next} />

        <label>
          Username
          <input id="username" name="username" autocomplete="username" required />
        </label>

        <label>
          Password
          <input id="password" type="password" name="password" autocomplete="current-password" required />
        </label>

        <button type="submit">Sign in</button>
      </form>
    </section>
  </main>
</BaseLayout>

<style>
  .admin-main {
    min-height: calc(100vh - 10rem);
    display: grid;
    place-items: center;
    padding-block: var(--space-12);
  }

  .admin-card {
    width: min(100%, 32rem);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-soft);
    padding: var(--space-6);
    display: grid;
    gap: var(--space-3);
  }

  .eyebrow {
    margin: 0;
    color: var(--color-accent-strong);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-family: var(--font-display);
    color: var(--color-text-strong);
    line-height: 1.2;
  }

  .copy,
  label {
    color: var(--color-text-muted);
  }

  .copy {
    margin: 0;
  }

  .error {
    margin: 0;
    color: var(--color-accent-strong);
    font-weight: 700;
  }

  .login-form {
    margin-top: var(--space-2);
    display: grid;
    gap: var(--space-2);
  }

  label {
    font-weight: 700;
  }

  input {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    color: var(--color-text-strong);
    font: inherit;
    padding: var(--space-2) var(--space-3);
  }

  button {
    margin-top: var(--space-2);
    border: 1px solid var(--color-accent);
    background: var(--color-accent);
    color: var(--color-on-accent);
    font: inherit;
    font-weight: 700;
    border-radius: var(--radius-pill);
    padding: var(--space-2) var(--space-4);
    width: fit-content;
    cursor: pointer;
  }

  button:hover {
    background: var(--color-accent-strong);
    border-color: var(--color-accent-strong);
  }
</style>
