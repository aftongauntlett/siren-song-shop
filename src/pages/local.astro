---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ResourceCard from '../components/ResourceCard.astro';

type LocalKindId = 'shops' | 'restaurants' | 'service' | 'visit';

type USStateCode = 'CA' | 'MN' | 'NC' | 'NY' | 'OR' | 'PA' | 'VA';

interface LocalKindTab {
  id: LocalKindId;
  label: string;
  description: string;
}

interface LocalEntry {
  name: string;
  url: string;
  description: string;
  kind: LocalKindId;
  state: USStateCode;
  city: string;
  zip: string;
}

const categories: LocalKindTab[] = [
