const byKind = (kind: LocalKindId) => localEntries.filter((entry) => entry.kind === kind);
const states = Array.from(new Set(localEntries.map((entry) => entry.state))).sort();
---

<BaseLayout
  title="Local Gems | Siren Song"
  description="Browse local shops, services, and places to visit. Filter by state to focus on what is nearby."
>
  <SiteNav />
  <main id="main-content" class="container">
    <section class="page-hero" aria-labelledby="local-heading">
      <div class="hero-head">
        <div class="hero-title-group">
          <p class="kicker">Local Gems</p>
          <h1 id="local-heading">Good Spots Nearby</h1>
        </div>

        <section class="filter-bar" aria-label="Filter local gems">
          <p id="state-filter-label" class="filter-label">State</p>
          <div class="state-dropdown" data-state-dropdown>
            <button
              type="button"
              class="state-trigger"
              data-state-trigger
              aria-haspopup="listbox"
              aria-expanded="false"
              aria-labelledby="state-filter-label state-filter-value"
            >
              <span id="state-filter-value" data-state-value>All states</span>
              <svg class="state-trigger-chevron" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </button>
            <ul class="state-options" data-state-options aria-label="State filter" hidden>
              <li>
                <button type="button" class="state-option state-option--active" data-state-option data-value="all">
                  All states
                </button>
              </li>
              {states.map((stateCode) => (
                <li>
                  <button type="button" class="state-option" data-state-option data-value={stateCode}>
                    {stateCode}
                  </button>
                </li>
              ))}
            </ul>
          </div>
        </section>
      </div>

      <p class="intro">
        Explore local picks by type, then filter by state. We are starting with North Carolina and
        expanding from there.
      </p>
    </section>

    <nav class="category-nav" aria-label="Browse local gem categories">
      <div class="category-select-wrap">
        <select
          id="local-category-select"
          class="category-select"
          data-kind-select
          aria-label="Local category"
        >
          {categories.map((category) => (
            <option value={category.id}>{category.label}</option>
          ))}
        </select>
      </div>
      <div class="category-list" role="tablist" aria-label="Local categories">
        {categories.map(({ id, label }, index) => (
          <div class="category-item">
            <button
              type="button"
              class:list={['category-tab', { 'category-tab--active': index === 0 }]}
              role="tab"
              aria-selected={index === 0 ? 'true' : 'false'}
              tabindex={index === 0 ? '0' : '-1'}
              aria-controls={`${id}-panel`}
              id={`${id}-tab`}
              data-kind-tab
              data-kind={id}
            >
              {label}
            </button>
          </div>
        ))}
      </div>
    </nav>

    {categories.map(({ id, label, description }, index) => {
      const entries = byKind(id);
      return (
        <section
          id={`${id}-panel`}
          aria-labelledby={`${id}-tab`}
          role="tabpanel"
          class="category-section"
          data-reveal
          data-kind-panel
          data-kind={id}
          hidden={index !== 0}
        >
          <header class="category-header">
            <h2 class="section-heading">{label}</h2>
            <p class="category-description">{description}</p>
          </header>
          <ul class="local-grid">
            {entries.map((entry) => (
              <li data-local-card data-state={entry.state}>
                <ResourceCard
                  name={entry.name}
                  url={entry.url}
                  description={entry.description}
                  location={`${entry.city}, ${entry.state} ${entry.zip}`}
                />
              </li>
            ))}
          </ul>
          <p class="empty-state" data-empty-state hidden={entries.length > 0}>
            No entries yet for this category.
          </p>
        </section>
      );
    })}
  </main>
  <SiteFooter />
</BaseLayout>

<script>
  const w = window as Window & { __sirenLocalTabsHookBound?: boolean };

  const initializeLocalTabs = () => {
    const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-kind-tab]'));
    const panels = Array.from(document.querySelectorAll<HTMLElement>('[data-kind-panel]'));
    const stateDropdown = document.querySelector<HTMLElement>('[data-state-dropdown]');
    const stateTrigger = document.querySelector<HTMLButtonElement>('[data-state-trigger]');
    const stateValueLabel = document.querySelector<HTMLElement>('[data-state-value]');
    const stateOptionsPanel = document.querySelector<HTMLElement>('[data-state-options]');
    const stateOptions = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-state-option]'));
    const kindSelect = document.querySelector<HTMLSelectElement>('[data-kind-select]');
    if (tabs.length === 0 || panels.length === 0) return;
    let selectedState = 'all';

    const getTabKind = (tab: HTMLButtonElement) => tab.dataset.kind;

    const applyStateFilter = () => {
      panels.forEach((panel) => {
        const cards = Array.from(panel.querySelectorAll<HTMLElement>('[data-local-card]'));
        cards.forEach((card) => {
          const state = card.dataset.state;
          card.hidden = selectedState !== 'all' && state !== selectedState;
        });

        const emptyState = panel.querySelector<HTMLElement>('[data-empty-state]');
        const visibleCount = cards.filter((card) => !card.hidden).length;
        if (emptyState) {
          emptyState.hidden = visibleCount > 0;
        }
      });
    };

    const closeStateOptions = () => {
      if (!stateTrigger || !stateOptionsPanel) return;
      stateOptionsPanel.hidden = true;
      stateTrigger.setAttribute('aria-expanded', 'false');
      if (stateDropdown) {
        delete stateDropdown.dataset.open;
      }
    };

    const openStateOptions = () => {
      if (!stateTrigger || !stateOptionsPanel) return;
      stateOptionsPanel.hidden = false;
      stateTrigger.setAttribute('aria-expanded', 'true');
      if (stateDropdown) {
        stateDropdown.dataset.open = 'true';
      }
    };

    const setSelectedState = (value: string, label: string) => {
      selectedState = value;
      if (stateValueLabel) {
        stateValueLabel.textContent = label;
      }

      stateOptions.forEach((option) => {
        const isSelected = option.dataset.value === value;
        option.classList.toggle('state-option--active', isSelected);
      });

      applyStateFilter();
    };

    const setActiveKind = (kind: string) => {
      tabs.forEach((tab) => {
        const isActive = tab.dataset.kind === kind;
        tab.setAttribute('aria-selected', String(isActive));
        tab.classList.toggle('category-tab--active', isActive);
        tab.tabIndex = isActive ? 0 : -1;
      });

      panels.forEach((panel) => {
        panel.hidden = panel.dataset.kind !== kind;
      });

      if (kindSelect && kindSelect.value !== kind) {
        kindSelect.value = kind;
      }

      applyStateFilter();
    };

    const setActiveByIndex = (index: number) => {
      const safeIndex = (index + tabs.length) % tabs.length;
      const nextTab = tabs[safeIndex];
      if (!nextTab) return;
      const kind = getTabKind(nextTab);
      if (!kind) return;
      setActiveKind(kind);
      nextTab.focus();
    };

    tabs.forEach((tab) => {
      if (tab.dataset.kindBound === 'true') return;

      tab.addEventListener('click', () => {
        const kind = getTabKind(tab);
        if (!kind) return;
        setActiveKind(kind);
      });

      tab.addEventListener('keydown', (event) => {
        const currentIndex = tabs.indexOf(tab);
        if (currentIndex < 0) return;

        if (event.key === 'ArrowRight') {
          event.preventDefault();
          setActiveByIndex(currentIndex + 1);
        }

        if (event.key === 'ArrowLeft') {
          event.preventDefault();
          setActiveByIndex(currentIndex - 1);
        }

        if (event.key === 'Home') {
          event.preventDefault();
          setActiveByIndex(0);
        }

        if (event.key === 'End') {
          event.preventDefault();
          setActiveByIndex(tabs.length - 1);
        }

        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          const kind = getTabKind(tab);
          if (!kind) return;
          setActiveKind(kind);
        }
      });

      tab.dataset.kindBound = 'true';
    });

    if (kindSelect && kindSelect.dataset.kindSelectBound !== 'true') {
      kindSelect.addEventListener('change', () => {
        setActiveKind(kindSelect.value);
      });
      kindSelect.dataset.kindSelectBound = 'true';
    }

    if (stateTrigger && stateOptionsPanel && stateTrigger.dataset.stateTriggerBound !== 'true') {
      stateTrigger.addEventListener('click', () => {
        if (stateOptionsPanel.hidden) {
          openStateOptions();
        } else {
          closeStateOptions();
        }
      });

      stateTrigger.addEventListener('keydown', (event) => {
        if (event.key === 'ArrowDown' || event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          openStateOptions();
        }

        if (event.key === 'Escape') {
          event.preventDefault();
          closeStateOptions();
        }
      });

      stateTrigger.dataset.stateTriggerBound = 'true';
    }

    stateOptions.forEach((option) => {
      if (option.dataset.stateOptionBound === 'true') return;

      option.addEventListener('click', () => {
        const value = option.dataset.value;
        if (!value) return;
        setSelectedState(value, option.textContent?.trim() ?? value);
        closeStateOptions();
      });

      option.dataset.stateOptionBound = 'true';
    });

    if (stateDropdown && stateDropdown.dataset.stateOutsideBound !== 'true') {
      document.addEventListener('click', (event) => {
        const target = event.target as Node;
        if (!stateDropdown.contains(target)) {
          closeStateOptions();
        }
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          closeStateOptions();
        }
      });

      stateDropdown.dataset.stateOutsideBound = 'true';
    }

    const firstTab = tabs.at(0);
    if (firstTab?.dataset.kind) {
      setActiveKind(firstTab.dataset.kind);
    }
  };

  initializeLocalTabs();

  if (!w.__sirenLocalTabsHookBound) {
    document.addEventListener('astro:page-load', initializeLocalTabs);
    w.__sirenLocalTabsHookBound = true;
  }
</script>

<style>
  .page-hero {
    padding: var(--space-12) 0 var(--space-8);
  }

  .hero-head {
    display: grid;
    gap: var(--space-3);
    align-items: end;
  }

  .kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent-teal);
    font-weight: 600;
    font-size: 0.8rem;
  }

  h1 {
    margin: var(--space-2) 0 var(--space-4);
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 1.15;
    color: var(--color-text-strong);
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .intro {
    margin: 0;
    color: var(--color-text-muted);
    max-width: 56ch;
  }

  .filter-bar {
    margin: 0;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .filter-label {
    margin: 0;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-text-strong);
  }

  .state-dropdown {
    position: relative;
    display: inline-flex;
    flex-direction: column;
    min-width: 11.5rem;
  }

  @media (min-width: 64rem) {
    .hero-head {
      grid-template-columns: minmax(0, 1fr) auto;
      column-gap: var(--space-6);
    }

    .filter-bar {
      justify-self: end;
      align-self: center;
    }

    h1 {
      margin-bottom: 0;
    }

    .intro {
      margin-top: var(--space-4);
    }
  }

  .state-trigger {
    width: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-md);
    background: color-mix(in oklab, var(--color-surface) 86%, transparent);
    color: var(--color-text-strong);
    padding: 0.5rem 0.85rem;
    font: inherit;
    font-weight: 600;
    line-height: 1.2;
    cursor: pointer;
    box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--color-accent-soft) 24%, transparent);
    transition: border-color 180ms ease, box-shadow 180ms ease, background-color 180ms ease;
  }

  .state-trigger:hover {
    border-color: color-mix(in oklab, var(--color-accent-soft) 64%, var(--color-border-soft));
    background: color-mix(in oklab, var(--color-surface) 92%, transparent);
  }

  .state-trigger:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
  }

  .state-trigger-chevron {
    color: var(--color-text-muted);
    flex-shrink: 0;
    transition: transform 180ms ease;
  }

  .state-dropdown[data-open='true'] .state-trigger-chevron {
    transform: rotate(180deg);
  }

  .state-options {
    list-style: none;
    position: absolute;
    top: calc(100% + 0.35rem);
    left: 0;
    right: 0;
    z-index: 10;
    margin: 0;
    padding: 0.35rem;
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-bg) 94%, transparent);
    box-shadow: 0 14px 28px -24px rgba(0, 0, 0, 0.42);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  .state-option {
    width: 100%;
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    padding: 0.45rem 0.6rem;
    background: transparent;
    color: var(--color-text-muted);
    text-align: left;
    font: inherit;
    font-weight: 600;
    cursor: pointer;
    transition: color 180ms ease, background-color 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  .state-option:hover,
  .state-option:focus-visible {
    color: var(--color-text-strong);
    background: var(--color-surface-strong);
    outline: none;
  }

  .state-option--active {
    color: var(--color-text-strong);
    background: var(--color-surface-strong);
    border-color: color-mix(in oklab, var(--color-accent-soft) 70%, var(--color-border-soft));
    box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--color-accent) 25%, transparent);
  }

  .category-nav {
    margin: var(--space-2) 0 var(--space-4);
  }

  .category-select-wrap {
    margin-bottom: var(--space-3);
  }

  .category-select {
    width: 100%;
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-sm);
    background: var(--color-surface-card);
    color: var(--color-text-strong);
    padding: 0.55rem 0.75rem;
    font: inherit;
  }

  .category-select:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
  }

  .category-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: nowrap;
    gap: 0;
    overflow-x: auto;
    border-bottom: 1px solid var(--color-border-soft);
  }

  :root:not([data-theme='dark']) .category-list {
    border-bottom-color: color-mix(in oklab, var(--color-accent-strong) 28%, var(--color-border-soft) 72%);
  }

  .category-item {
    flex: 0 0 auto;
  }

  .category-tab {
    display: inline-flex;
